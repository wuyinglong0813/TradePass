page { background: #f5f6f8; }

.page { padding: 24rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }

.card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.form-group { margin-bottom: 4rpx; }

.form-label {
  color: #999;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.form-input {
  color: #1a1a1a;
  font-size: 32rpx;
  font-weight: 600;
  width: 100%;
}

.cat-list { display: flex; flex-wrap: wrap; gap: 12rpx; }

.cat-item {
  background: #f5f5f5;
  border-radius: 8rpx;
  color: #666;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  transition: all 0.15s;
}

.cat-item.active {
  background: #ccfbf1;
  color: #0f766e;
  font-weight: 600;
}

.form-textarea {
  background: #f9fafb;
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #333;
  font-size: 26rpx;
  height: 500rpx;
  line-height: 1.8;
  padding: 20rpx 24rpx;
  width: 100%;
}

.btn-area { margin-top: 12rpx; }

.btn-save {
  background: linear-gradient(90deg, #0f766e, #14b8a6);
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  width: 100%;
}

.btn-save::after { border: none; }

.btn-delete {
  color: #ef4444;
  font-size: 28rpx;
  margin-top: 24rpx;
  text-align: center;
}
