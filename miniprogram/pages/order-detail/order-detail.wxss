.hero {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
}

.brand {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.company {
  font-size: 36rpx;
  font-weight: 600;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

/* 月份柱状图 */
.chart-bar {
  display: flex;
  gap: 8rpx;
  height: 200rpx;
  justify-content: space-between;
}

.bar-col {
  align-items: center;
  display: flex;
  flex: 1;
  flex-direction: column;
  height: 100%;
  justify-content: flex-end;
}

.bar {
  background: linear-gradient(180deg, #14b8a6, #0f766e);
  border-radius: 6rpx 6rpx 0 0;
  min-height: 8rpx;
  transition: height 0.3s;
  width: 100%;
}

.bar-label {
  color: #6b7280;
  font-size: 20rpx;
  margin-top: 8rpx;
}

/* 操作网格 */
.action-grid {
  display: grid;
  gap: 24rpx 16rpx;
  grid-template-columns: repeat(4, 1fr);
}

.action-item {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding: 16rpx 0;
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.action-label {
  color: #374151;
  font-size: 22rpx;
  text-align: center;
}

/* 最近订单 */
.order-row {
  align-items: center;
  border-bottom: 1rpx solid #eef2f7;
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
}

.order-row:last-child {
  border-bottom: none;
}

.order-info {
  align-items: center;
  display: flex;
  gap: 16rpx;
}

.order-dir {
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
}

.order-dir.sale {
  background: #dcfce7;
  color: #166534;
}

.order-dir.purchase {
  background: #dbeafe;
  color: #1e40af;
}

.order-date {
  color: #9ca3af;
  font-size: 24rpx;
}

.order-amount {
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 700;
}
