page { background: #f5f6f8; }

.page {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ===== 通用 ===== */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 24rpx;
  padding: 28rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.section-title {
  align-items: center;
  display: flex;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #1a1a1a;
}

.title-count {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 500;
  margin-left: 8rpx;
}

.arrow { color: #ccc; font-size: 36rpx; flex-shrink: 0; }

.page-end {
  color: #ccc;
  font-size: 22rpx;
  padding: 24rpx 0 40rpx;
  text-align: center;
}

/* ===== 双方公司头部 ===== */
.hero {
  background: linear-gradient(160deg, #0f766e, #14b8a6);
  margin-top: 0;
  border-radius: 0 0 20rpx 20rpx;
  padding: 36rpx 28rpx;
}

.hero-companies {
  align-items: center;
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.hc-side {
  align-items: center;
  display: flex;
  flex-direction: column;
  min-width: 140rpx;
}

.hc-avatar {
  align-items: center;
  border-radius: 24rpx;
  color: #fff;
  display: flex;
  font-size: 44rpx;
  font-weight: 700;
  height: 96rpx;
  justify-content: center;
  width: 96rpx;
}

.hc-avatar.my { background: rgba(255,255,255,0.18); }
.hc-avatar.cp { background: rgba(255,255,255,0.28); }

.hc-name {
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 12rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hc-tag {
  background: rgba(255,255,255,0.22);
  border-radius: 6rpx;
  color: #fff;
  font-size: 20rpx;
  margin-top: 6rpx;
  padding: 2rpx 16rpx;
}

.hc-connector {
  align-items: center;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hc-line {
  background: rgba(255,255,255,0.25);
  height: 1rpx;
  width: 48rpx;
}

.hc-icon {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; color: #fff; font-weight: 700;
}

/* ===== 柱状图 ===== */
.chart-bar {
  display: flex;
  gap: 4rpx;
  height: 160rpx;
  justify-content: space-between;
}

.bar-col {
  align-items: center;
  display: flex;
  flex: 1;
  flex-direction: column;
  height: 100%;
  justify-content: flex-end;
}

.bar {
  background: linear-gradient(180deg, #5eead4, #0f766e);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 6rpx;
  width: 70%;
}

.bar-label {
  color: #999;
  font-size: 18rpx;
  margin-top: 6rpx;
}

/* ===== 快捷操作 ===== */
.quick-actions {
  display: flex;
  gap: 0;
}

.qa-btn {
  align-items: center;
  display: flex;
  flex: 1;
  flex-direction: column;
  padding: 16rpx 0;
}

.qa-btn:active {
  background: #f9fafb;
  border-radius: 12rpx;
}

.qa-icon {
  width: 88rpx; height: 88rpx; border-radius: 50%; margin-bottom: 8rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #fff; font-weight: 700;
}

.qa-label {
  color: #555;
  font-size: 24rpx;
}

/* ===== 合同卡片 ===== */
.contract-card {
  border: 1rpx solid #eef0f2;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  transition: all 0.15s;
}

.contract-card:last-child {
  margin-bottom: 0;
}

.contract-card:active {
  background: #f9fafb;
  border-color: #d0ebe5;
}

.ct-top {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.ct-name {
  color: #1a1a1a;
  font-size: 30rpx;
  font-weight: 700;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ct-status {
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
  margin-left: 12rpx;
}

.ct-status.active {
  background: #dcfce7;
  color: #166534;
}

.ct-status.pending {
  background: #fef3c7;
  color: #92400e;
}

.ct-status.done {
  background: #f0f0f0;
  color: #888;
}

.ct-template {
  flex: 1;
}

.ct-template-label {
  color: #999;
  font-size: 22rpx;
}

.ct-dates {
  color: #999;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.ct-bottom {
  align-items: center;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.ct-amount-label {
  color: #999;
  display: block;
  font-size: 22rpx;
}

.ct-amount-value {
  color: #0f766e;
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 2rpx;
}

.ct-orders {
  align-items: baseline;
  display: flex;
  gap: 4rpx;
}

.ct-orders-count {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 700;
}

.ct-orders-label {
  color: #999;
  font-size: 22rpx;
}

.ct-bottom .arrow {
  margin-left: auto;
}

/* ===== 空状态 ===== */
.empty-hint {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding: 40rpx 0 24rpx;
}

.empty-icon { font-size: 52rpx; margin-bottom: 12rpx; }
.empty-text { color: #999; font-size: 26rpx; }

/* ===== 弹窗 ===== */
.mask {
  align-items: center;
  background: rgba(0,0,0,0.45);
  display: flex;
  inset: 0;
  justify-content: center;
  position: fixed;
  z-index: 200;
}

.modal {
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  margin: 80rpx 48rpx;
  max-width: 560rpx;
  padding: 40rpx;
  width: 100%;
}

.modal-title { font-size: 34rpx; font-weight: 700; margin-bottom: 20rpx; }

.modal-body {
  color: #4b5563;
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-line;
}

.modal-btn {
  background: #0f766e;
  border: none;
  border-radius: 12rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  height: 84rpx;
  line-height: 84rpx;
  margin-top: 32rpx;
  width: 100%;
}

.modal-btn::after { border: none; }
