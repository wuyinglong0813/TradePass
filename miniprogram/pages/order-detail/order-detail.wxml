<view class="page">
  <!-- 双方公司头部 -->
  <view class="hero card">
    <view class="hero-companies">
      <view class="hc-side">
        <view class="hc-avatar my">{{myCompanyName[0]}}</view>
        <view class="hc-name">{{myCompanyName}}</view>
        <view class="hc-tag">我方</view>
      </view>
      <view class="hc-connector">
        <view class="hc-line"></view>
        <view class="hc-icon">🤝</view>
        <view class="hc-line"></view>
      </view>
      <view class="hc-side">
        <view class="hc-avatar cp">{{counterpartyName[0]}}</view>
        <view class="hc-name">{{counterpartyName}}</view>
        <view class="hc-tag">供应方</view>
      </view>
    </view>
  </view>

  <!-- 月销售额趋势 -->
  <view class="card">
    <view class="section-title">月销售额趋势</view>
    <view class="chart-bar">
      <block wx:for="{{monthlySales}}" wx:key="month">
        <view class="bar-col">
          <view class="bar" style="height: {{item.percent}}%;"></view>
          <view class="bar-label">{{item.month}}月</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 快捷操作：合同模板 / 签订合同 -->
  <view class="card">
    <view class="quick-actions">
      <view class="qa-btn" wx:if="{{canSignContract}}" data-key="sign" bindtap="onAction">
        <view class="qa-icon">✍️</view>
        <view class="qa-label">签订合同</view>
      </view>
      <view class="qa-btn" wx:if="{{canReconciliation}}" data-key="reconciliation" bindtap="onAction">
        <view class="qa-icon">💰</view>
        <view class="qa-label">对账情况</view>
      </view>
    </view>
  </view>

  <!-- 已签合同列表 -->
  <view class="card">
    <view class="section-title">
      合同列表
      <text class="title-count" wx:if="{{contracts.length > 0}}">{{contracts.length}}份</text>
    </view>

    <view class="empty-hint" wx:if="{{contracts.length === 0}}">
      <view class="empty-icon">📋</view>
      <view class="empty-text">暂无签订合同</view>
    </view>

    <block wx:for="{{contracts}}" wx:key="id">
      <view class="contract-card" data-contract="{{item}}" bindtap="onContractTap">
        <view class="ct-top">
          <view class="ct-name">{{item.name}}</view>
          <view class="ct-status {{item.status === 'ACTIVE' ? 'active' : 'done'}}">{{item.statusText}}</view>
        </view>
        <view class="ct-dates">{{item.startDate}} ~ {{item.endDate}}</view>
        <view class="ct-bottom">
          <view class="ct-amount">
            <text class="ct-amount-label">合同金额</text>
            <text class="ct-amount-value">¥{{item.amount}}</text>
          </view>
          <view class="ct-template" wx:if="{{item.templateName}}">
            <text class="ct-template-label">模板：{{item.templateName}}</text>
          </view>
          <view class="arrow">›</view>
        </view>
      </view>
    </block>
  </view>

  <view class="page-end">— 已经到底了 —</view>

  <!-- 弹窗 -->
  <view class="mask" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal" catchtap="noop">
      <view class="modal-title">{{modalTitle}}</view>
      <view class="modal-body">{{modalContent}}</view>
      <button class="modal-btn" bindtap="closeModal">我知道了</button>
    </view>
  </view>
</view>
