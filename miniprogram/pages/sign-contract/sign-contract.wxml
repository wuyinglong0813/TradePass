<view class="page">
  <!-- 双方信息 -->
  <view class="party-bar">
    <view class="party-item">
      <view class="pi-avatar my">{{myCompanyName[0]}}</view>
      <view class="pi-name">{{myCompanyName}}</view>
      <view class="pi-tag">我方</view>
    </view>
    <view class="party-vs">签</view>
    <view class="party-item">
      <view class="pi-avatar cp">{{counterpartyName[0]}}</view>
      <view class="pi-name">{{counterpartyName}}</view>
      <view class="pi-tag">对方</view>
    </view>
  </view>

  <!-- 模板选择 -->
  <view class="card">
    <view class="form-group">
      <view class="form-label">合同模板</view>
      <picker mode="selector" range="{{templates}}" range-key="name" value="{{templateIndex}}" bindchange="onTemplateChange">
        <view class="form-picker">{{templates[templateIndex] ? templates[templateIndex].name : '请选择模板'}} ▾</view>
      </picker>
    </view>
  </view>

  <!-- 合同预览 -->
  <block wx:if="{{hasTemplate}}">
    <!-- 合同标题 -->
    <view class="card contract-title-card">
      <view class="ct-title">购销合同</view>
      <view class="ct-no">合同编号：签订时自动生成</view>
    </view>

    <!-- 头部字段 -->
    <view class="card">
      <view class="section-title">合同信息</view>
      <view class="field-row" wx:for="{{fields}}" wx:key="key">
        <view class="field-label">{{item.label}}</view>

        <block wx:if="{{item.type === 'date'}}">
          <picker mode="date" value="{{item.value}}" data-index="{{index}}" bindchange="onDateFieldChange">
            <view class="field-value date {{item.value ? '' : 'placeholder'}}">{{item.value || '请选择日期'}}</view>
          </picker>
        </block>

        <block wx:elif="{{!item.editable}}">
          <view class="field-value locked">
            <text class="locked-icon">🔒</text>
            <text class="locked-text">{{item.hint || '自动生成'}}</text>
          </view>
        </block>

        <block wx:else>
          <input class="field-input" placeholder="{{item.hint || ''}}" value="{{item.value}}" data-index="{{index}}" bindinput="onFieldChange"/>
        </block>
      </view>
    </view>

    <!-- 产品表格 -->
    <view class="card" wx:if="{{tableSection}}">
      <view class="section-title">{{tableSection.title}}</view>
      <scroll-view class="table-scroll" scroll-x enable-flex>
        <view class="table-wrap">
          <view class="table-row table-header">
            <view class="th" wx:for="{{tableSection.columns}}" wx:for-item="col" wx:key="*this">
              <text>{{col}}</text>
            </view>
            <view class="th th-del"></view>
          </view>
          <view class="table-row" wx:for="{{tableRows}}" wx:for-item="row" wx:for-index="ri" wx:key="ri">
            <view class="td" wx:for="{{tableSection.columns}}" wx:for-item="col" wx:for-index="ci" wx:key="ci">
              <block wx:if="{{ci === 5}}">
                <input class="td-input num auto" type="digit" value="{{row[ci]}}" disabled/>
              </block>
              <block wx:elif="{{ci >= 3}}">
                <input class="td-input num" type="digit" value="{{row[ci]}}" data-row="{{ri}}" data-col="{{ci}}" bindinput="onTableCellChange"/>
              </block>
              <block wx:else>
                <input class="td-input" type="text" value="{{row[ci]}}" data-row="{{ri}}" data-col="{{ci}}" bindinput="onTableCellChange"/>
              </block>
            </view>
            <view class="td td-del">
              <view class="del-btn" data-index="{{ri}}" bindtap="deleteTableRow">✕</view>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="table-add" bindtap="addTableRow">＋ 添加产品行</view>

      <view class="table-summary">
        <view class="sum-row">
          <text class="sum-label">合计：</text>
          <text class="sum-amount">¥{{totalAmount}}</text>
        </view>
        <view class="sum-row">
          <text class="sum-label">大写：</text>
          <text class="sum-chinese">{{totalAmountCn}}</text>
        </view>
      </view>
    </view>

    <!-- 条款（只读展示） -->
    <view class="card" wx:if="{{clauses.length > 0}}">
      <view class="section-title">合同条款</view>
      <view class="clause-ro" wx:for="{{clauses}}" wx:for-item="clause" wx:key="idx">
        <view class="clause-ro-title">{{clause._label}}{{clause.title}}</view>
        <view class="clause-ro-content">{{clause.content || '（无内容）'}}</view>
      </view>
    </view>
  </block>

  <!-- 空态 -->
  <view class="card empty-card" wx:if="{{!hasTemplate && templates.length === 0}}">
    <view class="empty-icon">📋</view>
    <view class="empty-text">暂无可用合同模板</view>
    <view class="empty-sub">请先在合同模板库中创建模板</view>
  </view>

  <!-- 提交 -->
  <view class="submit-area" wx:if="{{hasTemplate}}">
    <button class="submit-btn" bindtap="onSubmit">确认签订</button>
  </view>

  <view class="safe-bottom"></view>
</view>
