page { background: #f4f8fd; }

.page { padding: 24rpx; padding-bottom: calc(160rpx + env(safe-area-inset-bottom)); }

/* 双方信息 */
.party-bar {
  align-items: center;
  background: linear-gradient(160deg, #3498ff, #45a8ff);
  display: flex; justify-content: center;
  padding: 36rpx 40rpx; gap: 32rpx;
  border-radius: 16rpx; margin-bottom: 20rpx;
}
.party-item { align-items: center; display: flex; flex-direction: column; }
.pi-avatar {
  align-items: center; border-radius: 24rpx; color: #fff;
  display: flex; font-size: 40rpx; font-weight: 700;
  height: 88rpx; justify-content: center; width: 88rpx;
}
.pi-avatar.my { background: rgba(255,255,255,0.18); }
.pi-avatar.cp { background: rgba(255,255,255,0.28); }
.pi-name {
  color: #fff; font-size: 26rpx; font-weight: 600; margin-top: 10rpx;
  max-width: 160rpx; overflow: hidden; text-align: center;
  text-overflow: ellipsis; white-space: nowrap;
}
.pi-tag {
  background: rgba(255,255,255,0.22); border-radius: 6rpx;
  color: #fff; font-size: 20rpx; margin-top: 6rpx; padding: 2rpx 16rpx;
}
.party-vs image { border: 2rpx solid rgba(255,255,255,.22); border-radius: 50%; height: 76rpx; width: 76rpx; }

/* CARD */
.card {
  background: #fff; border-radius: 16rpx; margin-bottom: 16rpx;
  padding: 24rpx 28rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}
.section-title {
  font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx;
  padding-left: 12rpx; border-left: 6rpx solid #3498ff;
}

/* 表单 */
.form-group { margin-bottom: 0; }
.form-label { color: #999; font-size: 24rpx; margin-bottom: 12rpx; }
.form-picker { color: #3498ff; font-size: 30rpx; font-weight: 600; }

/* 合同标题 */
.contract-title-card { text-align: center; padding: 40rpx 28rpx; }
.ct-title { font-size: 40rpx; font-weight: 700; color: #162336; letter-spacing: 8rpx; margin-bottom: 12rpx; }
.ct-no { font-size: 24rpx; color: #999; }

/* 字段 */
.field-row {
  display: flex; align-items: center; padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.field-row:last-child { border-bottom: none; }
.field-label { font-size: 26rpx; color: #666; width: 210rpx; flex-shrink: 0; }
.field-input { flex: 1; font-size: 28rpx; color: #222; }
.field-input::placeholder { color: #ccc; }
.field-value { flex: 1; font-size: 28rpx; color: #222; }
.field-value.placeholder { color: #ccc; }
.field-value.date { color: #3498ff; }
.field-value.locked { display: flex; align-items: center; gap: 8rpx; color: #999; }
.locked-icon { height: 36rpx; width: 36rpx; }
.locked-text { font-size: 24rpx; color: #999; }

/* 产品表格 */
.table-scroll { width: 100%; }
.table-wrap { min-width: 900rpx; }
.table-row { display: flex; align-items: center; }
.table-header { background: #eaf4ff; border-radius: 8rpx 8rpx 0 0; }
.th {
  flex: 1; min-width: 130rpx; padding: 16rpx 6rpx;
  font-size: 24rpx; color: #3498ff; font-weight: 600; text-align: center;
}
.th-del { flex: 0 0 56rpx; min-width: 56rpx; }
.td { flex: 1; min-width: 130rpx; padding: 6rpx 3rpx; }
.td-del { flex: 0 0 56rpx; min-width: 56rpx; display: flex; justify-content: center; align-items: center; }
.td-input {
  width: 100%; height: 56rpx; font-size: 24rpx; color: #333;
  background: #fafafa; border-radius: 6rpx; text-align: center; padding: 0 4rpx; box-sizing: border-box;
}
.td-input.num { text-align: right; }
.td-input.auto { background: #eaf4ff; color: #3498ff; font-weight: 600; }
.del-btn {
  width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; color: #e53e3e; background: #fff5f5; border-radius: 50%;
}
.table-add {
  margin-top: 16rpx; padding: 14rpx; text-align: center;
  font-size: 26rpx; color: #3498ff; background: #eaf4ff; border-radius: 10rpx;
  border: 1rpx dashed #3498ff;
}
.table-summary {
  margin-top: 16rpx; padding: 20rpx; background: #fafafa; border-radius: 10rpx;
}
.sum-row { display: flex; align-items: center; margin-bottom: 8rpx; }
.sum-row:last-child { margin-bottom: 0; }
.sum-label { font-size: 26rpx; color: #666; width: 100rpx; flex-shrink: 0; }
.sum-amount { font-size: 30rpx; color: #e53e3e; font-weight: 700; }
.sum-chinese { font-size: 26rpx; color: #3498ff; font-weight: 600; }

/* 条款（只读） */
.clause-ro { margin-bottom: 16rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f5f5f5; }
.clause-ro:last-child { border-bottom: none; padding-bottom: 0; }
.clause-ro-title { font-size: 26rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.clause-ro-content { font-size: 26rpx; color: #666; line-height: 1.8; }

/* 空态 */
.empty-card { text-align: center; padding: 80rpx 28rpx; }
.empty-icon { height: 108rpx; margin-bottom: 16rpx; width: 108rpx; }
.empty-text { font-size: 28rpx; color: #999; margin-bottom: 8rpx; }
.empty-sub { font-size: 24rpx; color: #ccc; }

/* 提交 */
.submit-area {
  background: #fff; bottom: 0; left: 0; right: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  position: fixed; box-sizing: border-box; z-index: 10;
}
.submit-btn {
  background: linear-gradient(90deg, #3498ff, #45a8ff); border: none;
  border-radius: 48rpx; color: #fff; font-size: 32rpx; font-weight: 600;
  height: 96rpx; line-height: 96rpx; width: 100%;
}
.submit-btn::after { border: none; }
.safe-bottom { height: 60rpx; }
