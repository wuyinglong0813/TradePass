page { background: #f4f8fd; }
.recon-page { min-height: 100vh; padding-bottom: 38rpx; }
.recon-hero { background: linear-gradient(138deg,#45a8ff,#2478df 76%,#1557a8); color: #fff; overflow: hidden; padding: 36rpx 32rpx 80rpx; position: relative; }
.recon-hero image { height: 220rpx; opacity: .08; position: absolute; right: -30rpx; top: -42rpx; width: 220rpx; }
.hero-label { color: rgba(255,255,255,.68); font-size: 22rpx; position: relative; }
.hero-title { font-size: 35rpx; font-weight: 700; margin-top: 10rpx; max-width: 650rpx; overflow: hidden; position: relative; text-overflow: ellipsis; white-space: nowrap; }
.hero-date { color: rgba(255,255,255,.65); font-size: 22rpx; margin-top: 10rpx; position: relative; }
.overview-card { background: #fff; border: 1rpx solid #e3ebf5; border-radius: 28rpx; box-shadow: 0 14rpx 38rpx rgba(22, 49, 85,.08); display: grid; grid-template-columns: repeat(2,1fr); margin: -48rpx 24rpx 0; overflow: hidden; position: relative; }
.overview-item { border-bottom: 1rpx solid #edf2f8; border-right: 1rpx solid #edf2f8; padding: 25rpx 18rpx; text-align: center; }
.overview-item:nth-child(2n) { border-right: none; }
.overview-item:nth-child(n+3) { border-bottom: none; }
.overview-value { color: #1b2a3c; font-size: 32rpx; font-weight: 700; }
.overview-label { color: #909b98; font-size: 21rpx; margin-top: 5rpx; }
.overview-item.success .overview-value { color: #3498ff; }
.overview-item.warning .overview-value { color: #bd7420; }
.detail-card { background: #fff; border: 1rpx solid #e3ebf5; border-radius: 28rpx; box-shadow: 0 10rpx 32rpx rgba(22, 49, 85,.05); margin: 22rpx 24rpx 0; padding: 28rpx; }
.section-head { margin-bottom: 18rpx; }
.section-title { color: #162336; font-size: 30rpx; font-weight: 700; }
.section-sub { color: #929d9a; font-size: 21rpx; margin-top: 5rpx; }
.detail-item { border-bottom: 1rpx solid #edf2f8; padding: 22rpx 0; }
.detail-item:last-child { border-bottom: none; }
.item-head,.item-body { align-items: center; display: flex; }
.item-head { justify-content: space-between; }
.counterparty { color: #1b2a3c; font-size: 26rpx; font-weight: 700; }
.order-no { color: #7d8986; font-size: 22rpx; margin-top: 4rpx; }
.status { border-radius: 15rpx; font-size: 21rpx; padding: 5rpx 11rpx; }
.status.matched { background: #e7f2ff; color: #3498ff; }
.status.unmatched { background: #fff3d6; color: #9a6511; }
.item-body { justify-content: space-between; margin-top: 18rpx; }
.item-body > view { flex: 1; }
.meta-label { color: #9ba5a2; font-size: 20rpx; }
.meta-value { color: #45534f; font-size: 24rpx; margin-top: 4rpx; }
.difference { background: #fff4e1; border-radius: 14rpx; color: #9a6511; display: inline-block; font-size: 21rpx; margin-top: 14rpx; padding: 6rpx 12rpx; }
.page-end { color: #9aa4a1; font-size: 20rpx; padding: 32rpx 0 8rpx; text-align: center; }
