page { background: #f5f6f8; }

.page { padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }

/* 头部 */
.hero {
  background: linear-gradient(160deg, #0f766e, #14b8a6);
  padding: 32rpx 40rpx 36rpx;
}

.hero-name {
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.hero-date {
  color: rgba(255,255,255,0.7);
  font-size: 24rpx;
  margin-top: 6rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 24rpx;
  padding: 28rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #1a1a1a;
}

/* 概览 */
.ov-row {
  display: flex;
}

.ov-item {
  align-items: center;
  display: flex;
  flex: 1;
  flex-direction: column;
  padding: 12rpx 0;
}

.ov-value {
  color: #1a1a1a;
  font-size: 36rpx;
  font-weight: 700;
}

.ov-item.done .ov-value { color: #16a34a; }
.ov-item.warn .ov-value { color: #ef4444; }

.ov-label {
  color: #999;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.ov-divider {
  background: #f0f0f0;
  height: 1rpx;
  margin: 8rpx 0;
}

/* 对账明细 */
.detail-item {
  border-bottom: 1rpx solid #f5f5f5;
  padding: 20rpx 0;
}

.detail-item:last-child { border-bottom: none; }

.di-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.di-no {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 600;
}

.di-status {
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
}

.di-status.matched { background: #dcfce7; color: #166534; }
.di-status.unmatched { background: #fef3c7; color: #92400e; }

.di-body {
  display: flex;
  margin-top: 16rpx;
}

.di-col {
  flex: 1;
}

.di-col-label {
  color: #bbb;
  font-size: 22rpx;
}

.di-col-value {
  color: #555;
  font-size: 26rpx;
  margin-top: 4rpx;
}

.di-footer {
  margin-top: 12rpx;
}

.di-diff {
  background: #fef2f2;
  border-radius: 6rpx;
  color: #ef4444;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
}

/* 页尾 */
.page-end {
  color: #ccc;
  font-size: 22rpx;
  padding: 24rpx 0 40rpx;
  text-align: center;
}
