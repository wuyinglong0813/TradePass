<view class="recon-page">
  <view class="recon-hero">
    <image src="/images/brand-logo.svg" mode="aspectFit"/>
    <view class="hero-label">{{isGlobal ? '跨公司汇总工作台' : '双方对账明细'}}</view>
    <view class="hero-title">{{isGlobal ? pageTitle + '中心' : '与 ' + counterpartyName + ' 的' + pageTitle}}</view>
    <view class="hero-date">当前展示订单口径 · 发票数据源尚未接入</view>
  </view>

  <view class="overview-card">
    <view class="overview-item"><view class="overview-value">¥{{overview.totalSales}}</view><view class="overview-label">{{role === 'buyer' ? '采购总额' : '销售总额'}}</view></view>
    <view class="overview-item"><view class="overview-value">{{overview.totalInvoiced}}</view><view class="overview-label">已开票额·未接入</view></view>
    <view class="overview-item"><view class="overview-value">{{overview.matched}}</view><view class="overview-label">已对平·未计算</view></view>
    <view class="overview-item"><view class="overview-value">{{overview.unmatched}}</view><view class="overview-label">差异·未计算</view></view>
  </view>

  <view class="detail-card">
    <view class="section-head"><view><view class="section-title">{{isGlobal ? '跨公司对账事项' : '对账明细'}}</view><view class="section-sub">{{isGlobal ? '选择具体企业可查看完整双方明细' : '逐笔核对订单与发票'}}</view></view></view>
    <view class="detail-item" wx:for="{{items}}" wx:key="id" data-item="{{item}}" bindtap="onItemTap">
      <view class="item-head"><view><view class="counterparty" wx:if="{{isGlobal}}">{{item.counterpartyName}}</view><view class="order-no">{{item.orderNo}}</view></view><view class="status {{item.status === 'MATCHED' ? 'matched' : 'unmatched'}}">{{item.statusText}}</view></view>
      <view class="item-body">
        <view><view class="meta-label">{{role === 'buyer' ? '采购金额' : '销售金额'}}</view><view class="meta-value">¥{{item.salesAmount}}</view></view>
        <view><view class="meta-label">发票号码</view><view class="meta-value">{{item.invoiceNo}}</view></view>
        <view><view class="meta-label">开票金额</view><view class="meta-value">{{item.invoiceAmount}}</view></view>
      </view>
      <view class="difference">发票数据未接入，不生成虚假差异</view>
    </view>
    <view class="page-end" wx:if="{{!loading && items.length === 0}}">暂无可对账订单</view>
  </view>
  <view class="page-end">接入发票数据后可计算已对平金额与真实差异</view>
</view>
