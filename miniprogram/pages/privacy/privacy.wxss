/* ===== 隐私协议页 ===== */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6f7f9;
  overflow: hidden;
}

/* 顶部 logo */
.top-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.tl-icon {
  width: 160rpx;
  height: 160rpx;
}

.tl-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-top: 24rpx;
}

/* 协议正文卡片 */
.agree-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 28rpx;
  padding: 36rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.ac-text {
  font-size: 30rpx;
  color: #374151;
  line-height: 2.2;
}

.ac-bold {
  color: #111827;
  font-weight: 600;
}

.ac-link {
  color: #3b82f6;
}

/* 底部操作 */
.bottom-actions {
  margin-top: auto;
  padding: 32rpx 28rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.ba-check {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
}

.ba-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
}

.ba-checkbox.checked {
  background: #3b82f6;
  border-color: #3b82f6;
}

.ba-check-text {
  font-size: 26rpx;
  color: #6b7280;
}

.ba-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 48rpx;
  background: linear-gradient(90deg, #3b82f6, #2563eb);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}
.ba-btn::after { border: none; }

.ba-deny {
  text-align: center;
  color: #9ca3af;
  font-size: 28rpx;
  margin-top: 18rpx;
}

/* ===== 协议弹层 ===== */
.agreement-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.agreement-sheet {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  height: 80vh;
  position: relative;
  overflow: hidden;
}

.as-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.as-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.as-close {
  font-size: 36rpx;
  color: #9ca3af;
  padding: 8rpx;
}

.as-body {
  position: absolute;
  top: 90rpx;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx 40rpx;
  box-sizing: border-box;
}

.as-text {
  line-height: 1.8;
}

.h3 {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  margin: 24rpx 0 10rpx;
}

.p {
  font-size: 26rpx;
  color: #4b5563;
  margin-bottom: 8rpx;
  text-indent: 2em;
}
