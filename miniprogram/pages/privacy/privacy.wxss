/* ===== 隐私协议页 ===== */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f4f8fd;
  overflow: hidden;
}

/* 顶部 logo */
.top-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.tl-icon {
  width: 160rpx;
  height: 160rpx;
}

.tl-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #162336;
  margin-top: 24rpx;
}

/* 协议正文卡片 */
.agree-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 28rpx;
  padding: 36rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.ac-text {
  font-size: 30rpx;
  color: #374151;
  line-height: 2.2;
}

.ac-bold {
  color: #162336;
  font-weight: 600;
}

.ac-link {
  color: #45a8ff;
}

/* 底部操作 */
.bottom-actions {
  margin-top: auto;
  padding: 32rpx 28rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.ba-check {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
}

.ba-checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
}

.ba-checkbox.checked {
  background: #45a8ff;
  border-color: #45a8ff;
}

.ba-check-text {
  font-size: 26rpx;
  color: #6b7280;
}

.ba-check-text.error {
  color: #ef4444;
}

/* 抖动动画 */
.ba-check.shaking {
  animation: shake 0.4s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 50%, 90% { transform: translateX(-8rpx); }
  30%, 70% { transform: translateX(8rpx); }
}

.ba-checkbox.error {
  border-color: #ef4444 !important;
}

.ba-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 48rpx;
  background: linear-gradient(90deg, #45a8ff, #2478df);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}
.ba-btn::after { border: none; }

.ba-deny {
  text-align: center;
  color: #9ca3af;
  font-size: 28rpx;
  margin-top: 18rpx;
}

/* ===== 协议弹层 ===== */
.agreement-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.agreement-sheet {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  box-sizing: border-box;
  width: 100%;
  height: 80vh;
  max-width: 100vw;
  position: relative;
  overflow: hidden;
}

.as-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.as-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #162336;
}

.as-close {
  font-size: 36rpx;
  color: #9ca3af;
  padding: 8rpx;
}

.as-body {
  position: absolute;
  top: 90rpx;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 0 40rpx;
  box-sizing: border-box;
  max-width: 100%;
  overflow-x: hidden;
  width: 100%;
}

.as-body .privacy-scroll-content {
  margin: 0 32rpx;
  width: calc(100% - 64rpx);
}
