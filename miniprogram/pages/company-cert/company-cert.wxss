/* ===== 企业实名认证页 ===== */

/* ---- 已有企业：认证步骤 ---- */
.cert-banner {
  position: relative;
  background: linear-gradient(160deg, #0a6e63 0%, #0f766e 40%, #14b8a6 100%);
  padding: 44rpx 40rpx 40rpx;
  overflow: hidden;
}
.cert-banner-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}
.cert-c-lg { width: 260rpx; height: 260rpx; top: -70rpx; right: -50rpx; }
.cert-c-md { width: 140rpx; height: 140rpx; bottom: -30rpx; left: -30rpx; }
.cert-company-name { color: #fff; font-size: 38rpx; font-weight: 700; position: relative; z-index: 1; }
.cert-badge { display: inline-block; background: rgba(255,255,255,0.22); border-radius: 8rpx; color: #fff; font-size: 22rpx; margin-top: 16rpx; padding: 6rpx 18rpx; position: relative; z-index: 1; }
.cert-legal { color: rgba(255,255,255,0.85); font-size: 24rpx; margin-top: 14rpx; position: relative; z-index: 1; }
.cert-card { background: #fff; border-radius: 24rpx; margin: 20rpx 24rpx; padding: 32rpx 30rpx; }
.section-title { font-size: 32rpx; font-weight: 700; color: #111827; margin-bottom: 24rpx; }
.cert-row { display: flex; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.cert-row:last-child { border-bottom: none; }
.cert-row-left { display: flex; align-items: center; flex: 1; gap: 20rpx; }
.cert-step-num { width: 48rpx; height: 48rpx; border-radius: 50%; background: #e5e7eb; color: #9ca3af; font-size: 24rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.cert-step-num.done { background: #0f766e; color: #fff; }
.cert-step-info { flex: 1; }
.cert-step-title { font-size: 28rpx; font-weight: 600; color: #111827; }
.cert-step-desc { font-size: 23rpx; color: #9ca3af; margin-top: 4rpx; }
.cert-status { font-size: 24rpx; margin-right: 8rpx; white-space: nowrap; }
.arrow { color: #9ca3af; font-size: 40rpx; }

/* ---- Step1：协议确认 ---- */
.agree-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.agree-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 24rpx;
  padding: 32rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.agree-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}
.agree-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}
.agree-row:last-child { border-bottom: none; }
.agree-key {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}
.agree-val {
  font-size: 30rpx;
  color: #111827;
  font-weight: 500;
}

/* 底部区域 */
.agree-bottom {
  margin-top: auto;
  padding: 24rpx 24rpx 32rpx;
}
.agree-check-row {
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
  line-height: 1.6;
  margin-bottom: 24rpx;
}
.agree-checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  margin-right: 10rpx;
  margin-top: 2rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
}
.agree-checkbox.checked {
  background: #3b82f6;
  border-color: #3b82f6;
}
.agree-text {
  font-size: 24rpx;
  color: #6b7280;
}
.agree-link {
  font-size: 24rpx;
  color: #3b82f6;
}

.agree-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  border-radius: 48rpx;
  background: linear-gradient(90deg, #3b82f6, #2563eb);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}
.agree-btn::after { border: none; }

.agree-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  gap: 8rpx;
}
.agree-footer-icon { width: 36rpx; height: 36rpx; }
.agree-footer-text { font-size: 22rpx; color: #9ca3af; }

/* ---- Step2：认证方式 ---- */
.auth-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 24rpx;
  padding: 32rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.auth-type-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}
.auth-type-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

/* 认证方式选项 */
.auth-options {
  display: flex;
  gap: 20rpx;
}
.auth-option {
  flex: 1;
  border: 2rpx solid #e5e7eb;
  border-radius: 20rpx;
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.auth-option.active {
  border-color: #0f766e;
  background: #f0fdfa;
}
.auth-option-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}
.auth-option-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}
.auth-option-check {
  position: absolute;
  top: 10rpx;
  right: 14rpx;
  width: 36rpx;
  height: 36rpx;
  background: #0f766e;
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 手机号认证表单 */
.form-item {
  margin-bottom: 28rpx;
}
.label {
  color: #374151;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.input {
  background: #f5f7fa;
  border: 1rpx solid #eef2f7;
  border-radius: 16rpx;
  box-sizing: border-box;
  color: #111827;
  font-size: 30rpx;
  height: 92rpx;
  padding: 0 28rpx;
  width: 100%;
}
.sms-row {
  display: flex;
  gap: 16rpx;
}
.sms-input {
  flex: 1;
}
.sms-btn {
  width: 200rpx;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: #f0fdfa;
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 16rpx;
  flex-shrink: 0;
}

/* 人脸认证 */
.face-desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
  text-align: center;
  padding: 32rpx 0;
}

/* 提交按钮 */
.submit-btn {
  background: linear-gradient(90deg, #0f766e, #14b8a6);
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  width: 100%;
}
.submit-btn::after { border: none; }
