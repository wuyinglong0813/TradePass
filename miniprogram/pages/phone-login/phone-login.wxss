page { background: #fff; }

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0 56rpx;
  box-sizing: border-box;
}

/* ===== 品牌区 ===== */
.branding {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding-top: 40rpx;
  padding-bottom: 48rpx;
}

.logo {
  height: 150rpx;
  width: 150rpx;
}

.app-name {
  color: #1a1a1a;
  font-size: 46rpx;
  font-weight: 700;
  margin-top: 24rpx;
}

.app-desc {
  color: #999;
  font-size: 24rpx;
  margin-top: 10rpx;
}

/* ===== 表单 ===== */
.input-row {
  align-items: center;
  background: #f7f8fa;
  border-radius: 16rpx;
  display: flex;
  height: 100rpx;
  margin-bottom: 20rpx;
  padding: 0 28rpx;
}

.country-code {
  border-right: 2rpx solid #e5e5e5;
  color: #333;
  font-size: 30rpx;
  font-weight: 500;
  margin-right: 20rpx;
  padding-right: 20rpx;
}

.phone-input,
.code-input {
  color: #333;
  flex: 1;
  font-size: 30rpx;
}

.phone-input::placeholder,
.code-input::placeholder {
  color: #bbb;
}

.code-btn {
  color: #0f766e;
  flex-shrink: 0;
  font-size: 26rpx;
  margin-left: 16rpx;
  white-space: nowrap;
}

.code-btn.sending {
  color: #999;
}

.btn-submit {
  align-items: center;
  background: linear-gradient(90deg, #0f766e, #14b8a6);
  border: none;
  border-radius: 48rpx;
  color: #fff;
  display: flex;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  justify-content: center;
  letter-spacing: 2rpx;
  margin-top: 16rpx;
  width: 100%;
}

.btn-submit::after { border: none; }

/* ===== 协议 ===== */
.agree-row {
  align-items: center;
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.agree-check {
  align-items: center;
  border: 2rpx solid #d0d0d0;
  border-radius: 50%;
  color: #fff;
  display: flex;
  flex-shrink: 0;
  font-size: 20rpx;
  height: 32rpx;
  justify-content: center;
  margin-right: 10rpx;
  width: 32rpx;
}

.agree-check.on {
  background: #0f766e;
  border-color: #0f766e;
}

.agree-label {
  color: #999;
  font-size: 24rpx;
  line-height: 1.5;
}

.agree-link {
  color: #0f766e;
}

.agree-hint {
  color: #bbb;
  font-size: 22rpx;
  margin-top: 12rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  text-align: center;
}

/* ===== 协议弹窗 ===== */
.mask {
  align-items: center;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  inset: 0;
  justify-content: center;
  position: fixed;
  z-index: 200;
}

.modal {
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  margin: 80rpx 48rpx;
  max-height: 75vh;
  padding: 40rpx;
  width: 100%;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.modal-body {
  flex: 1;
  max-height: 45vh;
}

.h2 {
  font-size: 28rpx;
  font-weight: 700;
  margin: 16rpx 0 12rpx;
}

.p {
  color: #4b5563;
  font-size: 26rpx;
  line-height: 2;
}

.modal-btn {
  background: #0f766e;
  border-radius: 12rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  height: 84rpx;
  line-height: 84rpx;
  margin-top: 24rpx;
  width: 100%;
}

.modal-btn::after { border: none; }
