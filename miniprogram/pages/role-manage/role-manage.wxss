.section-head { align-items: center; display: flex; justify-content: space-between; }
.title { font-size: 32rpx; font-weight: 700; }
.add-btn { background: #0f766e; border-radius: 8rpx; color: #fff; font-size: 24rpx; padding: 8rpx 20rpx; }
.role-card { position: relative; }
.role-name { font-size: 28rpx; font-weight: 600; margin-bottom: 8rpx; }
.role-perms { color: #6b7280; font-size: 22rpx; }
.arrow { color: #9ca3af; font-size: 48rpx; position: absolute; right: 0; top: 50%; transform: translateY(-50%); }
.empty { color: #6b7280; padding: 40rpx 0; text-align: center; }
.modal-mask { align-items: center; background: rgba(0,0,0,0.45); bottom: 0; display: flex; justify-content: center; left: 0; position: fixed; right: 0; top: 0; z-index: 100; }
.modal-card { background: #fff; border-radius: 20rpx; max-height: 80vh; overflow-y: auto; margin: 0 40rpx; padding: 40rpx; width: 100%; }
.modal-title { font-size: 34rpx; font-weight: 700; margin-bottom: 24rpx; }
.form-input { background: #f3f4f6; border-radius: 12rpx; font-size: 28rpx; margin-bottom: 24rpx; padding: 18rpx 24rpx; width: 100%; box-sizing: border-box; }
.perm-title { font-size: 26rpx; color: #6b7280; margin-bottom: 12rpx; }
.perm-list { margin-bottom: 24rpx; }
.perm-item { align-items: center; display: flex; gap: 16rpx; padding: 14rpx 0; }
.perm-check { border: 2rpx solid #d1d5db; border-radius: 6rpx; color: #fff; font-size: 20rpx; height: 36rpx; line-height: 36rpx; text-align: center; width: 36rpx; }
.perm-check.checked { background: #0f766e; border-color: #0f766e; }
.perm-label { font-size: 26rpx; }
.modal-btns { display: flex; gap: 16rpx; margin-top: 8rpx; }
.btn-cancel { background: #f3f4f6; border-radius: 12rpx; color: #6b7280; flex: 1; font-size: 28rpx; padding: 18rpx 0; text-align: center; }
.btn-confirm { background: #0f766e; border-radius: 12rpx; color: #fff; flex: 1; font-size: 28rpx; font-weight: 600; padding: 18rpx 0; text-align: center; }
.btn-delete { color: #ef4444; font-size: 26rpx; padding: 18rpx 0; text-align: center; }
