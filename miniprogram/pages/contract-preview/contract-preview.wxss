page { background: #f5f6f8; }

.page {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ===== 合同信息头 ===== */
.contract-header {
  background: linear-gradient(160deg, #0f766e, #14b8a6);
  padding: 32rpx 40rpx 36rpx;
}

.ch-name {
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
}

.ch-party {
  color: rgba(255,255,255,0.75);
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* ===== Tab ===== */
.tabs {
  background: #fff;
  display: flex;
  margin-bottom: 20rpx;
}

.tab-item {
  color: #666;
  flex: 1;
  font-size: 28rpx;
  padding: 26rpx 0 20rpx;
  position: relative;
  text-align: center;
}

.tab-item.active {
  color: #0f766e;
  font-weight: 700;
}

.tab-item.active::after {
  background: #0f766e;
  bottom: 0;
  content: '';
  height: 6rpx;
  left: 50%;
  position: absolute;
  transform: translateX(-50%);
  width: 40rpx;
  border-radius: 3rpx;
}

/* ===== 列表 ===== */
.list {
  padding: 0 24rpx;
}

.list-empty {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding: 100rpx 0;
}

.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-text { color: #999; font-size: 28rpx; }

/* ===== 订单卡片 ===== */
.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.order-card:active { background: #f9fafb; }

.oc-top {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.oc-no {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 600;
}

.oc-status {
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
}

.oc-status.done { background: #dcfce7; color: #166534; }
.oc-status.shipped { background: #dbeafe; color: #1e40af; }
.oc-status.pending { background: #fef3c7; color: #92400e; }

.oc-body {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
}

.oc-product {
  color: #555;
  font-size: 26rpx;
}

.oc-qty {
  color: #999;
  font-size: 24rpx;
}

.oc-bottom {
  align-items: center;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
  padding-top: 14rpx;
}

.oc-date {
  color: #bbb;
  font-size: 22rpx;
}

.oc-amount {
  color: #0f766e;
  font-size: 30rpx;
  font-weight: 700;
}

/* ===== 合同详情卡片 ===== */
.detail-loading {
  align-items: center;
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text { color: #999; font-size: 28rpx; }

.detail-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.d-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.d-name {
  color: #1a1a1a;
  font-size: 34rpx;
  font-weight: 700;
  flex: 1;
  margin-right: 16rpx;
}

.d-status {
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  padding: 6rpx 18rpx;
  white-space: nowrap;
}

.d-status.status-active { background: #dcfce7; color: #166534; }
.d-status.status-pending { background: #fef3c7; color: #92400e; }
.d-status.status-rejected { background: #fee2e2; color: #991b1b; }
.d-status.status-done { background: #e0e7ff; color: #3730a3; }

.d-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
}

.d-row + .d-row {
  border-top: 1rpx solid #f8f8f8;
}

.d-label {
  color: #888;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.d-value {
  color: #333;
  font-size: 28rpx;
  text-align: right;
  word-break: break-all;
}

.d-amount {
  color: #0f766e;
  font-size: 32rpx;
  font-weight: 700;
}

.d-date {
  color: #999;
  font-size: 26rpx;
}

/* 合同条款 */
.d-terms {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.d-terms-title {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.d-terms-content {
  background: #f9fafb;
  border-radius: 12rpx;
  color: #444;
  font-size: 26rpx;
  line-height: 1.8;
  padding: 20rpx 24rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.d-terms-empty {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding: 40rpx 0 20rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 28rpx;
}

/* ===== 详情面板 ===== */
.mask {
  align-items: flex-end;
  animation: fadeIn 0.25s;
  background: rgba(0,0,0,0.45);
  bottom: 0;
  display: flex;
  justify-content: center;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 100;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.panel {
  animation: slideUp 0.3s;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  overflow-y: auto;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  width: 100%;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.panel-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 36rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.panel-title {
  color: #1a1a1a;
  font-size: 34rpx;
  font-weight: 700;
}

.panel-close {
  color: #999;
  font-size: 36rpx;
  padding: 8rpx;
  line-height: 1;
}

/* 信息字段 */
.panel-fields {
  padding: 20rpx 32rpx;
}

.pf-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
}

.pf-row + .pf-row {
  border-top: 1rpx solid #f8f8f8;
}

.pf-label {
  color: #888;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.pf-value {
  color: #333;
  font-size: 28rpx;
  text-align: right;
  word-break: break-all;
}

.pf-value.hl {
  background: #dcfce7;
  border-radius: 6rpx;
  color: #166534;
  font-weight: 600;
  font-size: 24rpx;
  padding: 4rpx 14rpx;
}

.pf-value.amount {
  color: #0f766e;
  font-size: 32rpx;
  font-weight: 700;
}

.panel-btn-wrap {
  padding: 16rpx 32rpx 16rpx;
}

.panel-btn {
  background: #f5f5f5;
  border: none;
  border-radius: 12rpx;
  color: #666;
  font-size: 30rpx;
  padding: 20rpx 0;
  text-align: center;
  width: 100%;
}

/* 物流时间线 */
.timeline {
  padding: 28rpx 32rpx 8rpx;
}

.tl-item {
  display: flex;
  padding-bottom: 32rpx;
  position: relative;
}

.tl-dot {
  align-items: center;
  border-radius: 50%;
  display: flex;
  height: 36rpx;
  justify-content: center;
  margin-right: 20rpx;
  width: 36rpx;
  flex-shrink: 0;
  border: 2rpx solid #ddd;
  background: #fff;
  z-index: 1;
}

.tl-dot-inner {
  border-radius: 50%;
  height: 16rpx;
  width: 16rpx;
  background: #ddd;
}

.tl-dot.done {
  border-color: #0f766e;
}

.tl-dot.done .tl-dot-inner {
  background: #0f766e;
}

.tl-dot.active {
  border-color: #14b8a6;
  box-shadow: 0 0 0 6rpx rgba(20,184,166,0.15);
}

.tl-dot.active .tl-dot-inner {
  background: #14b8a6;
}

/* 时间线竖线 */
.tl-item::after {
  content: '';
  position: absolute;
  left: 17rpx;
  top: 36rpx;
  bottom: 0;
  width: 2rpx;
  background: #e8e8e8;
}

.tl-item:last-child::after {
  display: none;
}

.tl-info {
  flex: 1;
  min-width: 0;
}

.tl-title {
  color: #999;
  font-size: 26rpx;
  line-height: 1.5;
}

.tl-title.active {
  color: #0f766e;
  font-weight: 600;
}

.tl-time {
  color: #bbb;
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* ===== 页尾 ===== */
.page-end {
  color: #ccc; font-size: 22rpx; padding: 24rpx 0 40rpx; text-align: center;
}

/* ===== 结构化合同 ===== */
.card {
  background: #fff; border-radius: 16rpx; margin: 0 24rpx 16rpx;
  padding: 24rpx 28rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}
.section-title {
  font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx;
  padding-left: 12rpx; border-left: 6rpx solid #0f766e;
}

.s-title-card { text-align: center; padding: 36rpx 28rpx; }
.s-ct-title { font-size: 38rpx; font-weight: 700; color: #1a1a1a; letter-spacing: 6rpx; margin-bottom: 10rpx; }
.s-ct-no { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.s-status { display: inline-block; padding: 4rpx 20rpx; border-radius: 6rpx; font-size: 22rpx; }
.s-status.status-active { background: #dcfce7; color: #166534; }
.s-status.status-pending { background: #fef3c7; color: #92400e; }
.s-status.status-rejected { background: #fee2e2; color: #991b1b; }
.s-status.status-done { background: #e0e7ff; color: #3730a3; }

.s-row { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.s-row:last-child { border-bottom: none; }
.s-label { font-size: 26rpx; color: #666; width: 200rpx; flex-shrink: 0; }
.s-value { font-size: 28rpx; color: #222; flex: 1; }

/* 表格 */
.table-scroll { width: 100%; }
.table-wrap { min-width: 900rpx; }
.table-row { display: flex; }
.table-header { background: #f0fdf4; border-radius: 8rpx 8rpx 0 0; }
.th { flex: 1; min-width: 130rpx; padding: 14rpx 6rpx; font-size: 24rpx; color: #0f766e; font-weight: 600; text-align: center; }
.td { flex: 1; min-width: 130rpx; padding: 10rpx 6rpx; text-align: center; }
.td-text { font-size: 24rpx; color: #333; }
.table-summary { margin-top: 12rpx; padding: 16rpx 20rpx; background: #fafafa; border-radius: 10rpx; }
.sum-row { display: flex; margin-bottom: 6rpx; }
.sum-row:last-child { margin-bottom: 0; }
.sum-label { font-size: 26rpx; color: #666; width: 100rpx; }
.sum-amount { font-size: 28rpx; color: #e53e3e; font-weight: 700; }
.sum-chinese { font-size: 26rpx; color: #0f766e; font-weight: 600; }

/* 条款 */
.clause-block { margin-bottom: 16rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f5f5f5; }
.clause-block:last-child { border-bottom: none; padding-bottom: 0; }
.clause-title { font-size: 26rpx; font-weight: 600; color: #0f766e; margin-bottom: 8rpx; }
.clause-text { font-size: 26rpx; color: #555; line-height: 1.8; }
