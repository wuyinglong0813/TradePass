page { background: #f5f6f8; }

.page {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ===== 合同信息头 ===== */
.contract-header {
  background: linear-gradient(160deg, #0f766e, #14b8a6);
  padding: 32rpx 40rpx 36rpx;
}

.ch-name {
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
}

.ch-party {
  color: rgba(255,255,255,0.75);
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* ===== Tab ===== */
.tabs {
  background: #fff;
  display: flex;
  margin-bottom: 20rpx;
}

.tab-item {
  color: #666;
  flex: 1;
  font-size: 28rpx;
  padding: 26rpx 0 20rpx;
  position: relative;
  text-align: center;
}

.tab-item.active {
  color: #0f766e;
  font-weight: 700;
}

.tab-item.active::after {
  background: #0f766e;
  bottom: 0;
  content: '';
  height: 6rpx;
  left: 50%;
  position: absolute;
  transform: translateX(-50%);
  width: 40rpx;
  border-radius: 3rpx;
}

/* ===== 列表 ===== */
.list {
  padding: 0 24rpx;
}

.list-empty {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding: 100rpx 0;
}

.empty-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.empty-text { color: #999; font-size: 28rpx; }

/* ===== 订单卡片 ===== */
.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.order-card:active { background: #f9fafb; }

.oc-top {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.oc-no {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 600;
}

.oc-status {
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
}

.oc-status.done { background: #dcfce7; color: #166534; }
.oc-status.shipped { background: #dbeafe; color: #1e40af; }
.oc-status.pending { background: #fef3c7; color: #92400e; }

.oc-body {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
}

.oc-product {
  color: #555;
  font-size: 26rpx;
}

.oc-qty {
  color: #999;
  font-size: 24rpx;
}

.oc-bottom {
  align-items: center;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
  padding-top: 14rpx;
}

.oc-date {
  color: #bbb;
  font-size: 22rpx;
}

.oc-amount {
  color: #0f766e;
  font-size: 30rpx;
  font-weight: 700;
}

/* ===== 页尾 ===== */
.page-end {
  color: #ccc;
  font-size: 22rpx;
  padding: 24rpx 0 40rpx;
  text-align: center;
}
