  color: #666;
  font-size: 30rpx;
  padding: 20rpx 0;
  text-align: center;
  width: 100%;
}

/* 物流时间线 */
.timeline {
  padding: 28rpx 32rpx 8rpx;
}

.tl-item {
  display: flex;
  padding-bottom: 32rpx;
  position: relative;
}

.tl-dot {
  align-items: center;
  border-radius: 50%;
  display: flex;
  height: 36rpx;
  justify-content: center;
  margin-right: 20rpx;
  width: 36rpx;
  flex-shrink: 0;
  border: 2rpx solid #ddd;
  background: #fff;
  z-index: 1;
}

.tl-dot-inner {
  border-radius: 50%;
  height: 16rpx;
  width: 16rpx;
  background: #ddd;
}

.tl-dot.done {
  border-color: #3498ff;
}

.tl-dot.done .tl-dot-inner {
  background: #3498ff;
}

.tl-dot.active {
  border-color: #45a8ff;
  box-shadow: 0 0 0 6rpx rgba(52,152,255,0.15);
}

.tl-dot.active .tl-dot-inner {
  background: #45a8ff;
}

/* 时间线竖线 */
.tl-item::after {
  content: '';
  position: absolute;
  left: 17rpx;
  top: 36rpx;
  bottom: 0;
  width: 2rpx;
  background: #e8e8e8;
}

.tl-item:last-child::after {
  display: none;
}

.tl-info {
  flex: 1;
  min-width: 0;
}

.tl-title {
  color: #999;
  font-size: 26rpx;
  line-height: 1.5;
}

.tl-title.active {
  color: #3498ff;
  font-weight: 600;
}

.tl-time {
  color: #bbb;
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* ===== 页尾 ===== */
.page-end {
  color: #ccc; font-size: 22rpx; padding: 24rpx 0 40rpx; text-align: center;
}

/* ===== 结构化合同 ===== */
.card {
  background: #fff; border-radius: 16rpx; margin: 0 24rpx 16rpx;
  padding: 24rpx 28rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}
.section-title {
  font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx;
  padding-left: 12rpx; border-left: 6rpx solid #3498ff;
}

.s-title-card { text-align: center; padding: 36rpx 28rpx; }
.s-ct-title { font-size: 38rpx; font-weight: 700; color: #1a1a1a; letter-spacing: 6rpx; margin-bottom: 10rpx; }
.s-ct-no { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.s-status { display: inline-block; padding: 4rpx 20rpx; border-radius: 6rpx; font-size: 22rpx; }
.s-status.status-active { background: #dcfce7; color: #166534; }
.s-status.status-pending { background: #fef3c7; color: #92400e; }
.s-status.status-rejected { background: #fee2e2; color: #991b1b; }
.s-status.status-done { background: #e0e7ff; color: #3730a3; }

.s-row { display: flex; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.s-row:last-child { border-bottom: none; }
.s-label { font-size: 26rpx; color: #666; width: 200rpx; flex-shrink: 0; }
.s-value { font-size: 28rpx; color: #222; flex: 1; }

/* 表格 */
.table-scroll { width: 100%; }
.table-wrap { min-width: 900rpx; }
.table-row { display: flex; }
.table-header { background: #edf6ff; border-radius: 8rpx 8rpx 0 0; }
.th { flex: 1; min-width: 130rpx; padding: 14rpx 6rpx; font-size: 24rpx; color: #3498ff; font-weight: 600; text-align: center; }
.td { flex: 1; min-width: 130rpx; padding: 10rpx 6rpx; text-align: center; }
.td-text { font-size: 24rpx; color: #333; }
.table-summary { margin-top: 12rpx; padding: 16rpx 20rpx; background: #fafafa; border-radius: 10rpx; }
.sum-row { display: flex; margin-bottom: 6rpx; }
.sum-row:last-child { margin-bottom: 0; }
.sum-label { font-size: 26rpx; color: #666; width: 100rpx; }
.sum-amount { font-size: 28rpx; color: #e53e3e; font-weight: 700; }
.sum-chinese { font-size: 26rpx; color: #3498ff; font-weight: 600; }

/* 条款 */
.clause-block { margin-bottom: 16rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f5f5f5; }
.clause-block:last-child { border-bottom: none; padding-bottom: 0; }
.clause-title { font-size: 26rpx; font-weight: 600; color: #3498ff; margin-bottom: 8rpx; }
.clause-text { font-size: 26rpx; color: #555; line-height: 1.8; }
