/* ===== 合同详情卡片 ===== */
.detail-loading {
  align-items: center;
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text { color: #999; font-size: 28rpx; }

/* ===== PDF 合同详情 ===== */
.pdf-viewer {
  background: #e8e8e8;
  padding: 18rpx 20rpx 32rpx;
}

.pdf-state {
  align-items: center;
  color: #666;
  display: flex;
  font-size: 22rpx;
  justify-content: center;
  margin-bottom: 16rpx;
}

.pdf-state-dot {
  background: #aab0b6;
  border-radius: 50%;
  height: 12rpx;
  margin-right: 10rpx;
  width: 12rpx;
}

.pdf-state-dot.ready { background: #16a46d; }

.pdf-paper {
  background: #fff;
  box-shadow: 0 5rpx 18rpx rgba(0, 0, 0, .16);
  box-sizing: border-box;
  color: #111;
  margin: 0 auto;
  min-height: 1004rpx;
  padding: 84rpx 72rpx 62rpx;
  position: relative;
  width: 100%;
}

.pdf-paper:active { opacity: .96; }

.pdf-paper-title {
  font-family: serif;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 18rpx;
  margin-bottom: 22rpx;
  padding-left: 18rpx;
  text-align: center;
}

.pdf-paper-head {
  display: flex;
  font-family: serif;
  font-size: 16rpx;
  justify-content: space-between;
  line-height: 1.45;
}

.pdf-paper-head > view:first-child {
  max-width: 58%;
}

.pdf-section-line {
  font-family: serif;
  font-size: 16rpx;
  line-height: 1.4;
  margin-top: 5rpx;
}

.pdf-mini-table {
  border-left: 1rpx solid #222;
  border-top: 1rpx solid #222;
}

.pdf-mini-row {
  display: grid;
  grid-template-columns: 1.05fr 1.45fr .65fr .75fr .85fr 1fr .8fr;
  min-height: 28rpx;
}

.pdf-mini-row > view {
  border-bottom: 1rpx solid #222;
  border-right: 1rpx solid #222;
  box-sizing: border-box;
  color: #222;
  font-family: serif;
  font-size: 13rpx;
  min-width: 0;
  padding: 3rpx 2rpx;
  text-align: center;
}

.pdf-mini-header { background: #f5f5f5; }

.pdf-clause-lines {
  padding-top: 14rpx;
}

.pdf-clause-lines > view {
  border-bottom: 2rpx solid #333;
  height: 22rpx;
  opacity: .72;
}

.pdf-sign-table {
  border-left: 1rpx solid #222;
  border-top: 1rpx solid #222;
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin-top: 18rpx;
}

.pdf-sign-table > view {
  border-bottom: 1rpx solid #222;
  border-right: 1rpx solid #222;
  display: flex;
  flex-direction: column;
}

.pdf-sign-table text {
  border-bottom: 1rpx solid #222;
  font-family: serif;
  font-size: 13rpx;
  min-height: 22rpx;
  padding: 2rpx 4rpx;
}

.pdf-sign-table text:first-child {
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.pdf-sign-table text:last-child { border-bottom: 0; }

.pdf-open-hint {
  bottom: 20rpx;
  color: #777;
  font-size: 20rpx;
  left: 0;
  position: absolute;
  right: 0;
  text-align: center;
}

.pdf-actions {
  display: grid;
  gap: 18rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 24rpx;
}

.pdf-button {
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 82rpx;
  margin: 0;
  padding: 0;
}

.pdf-button::after { border: 0; }

.pdf-button.primary {
  background: #3498ff;
  color: #fff;
}

.pdf-button.secondary {
  background: #fff;
  border: 1rpx solid #3498ff;
  color: #3498ff;
}

.pdf-button[disabled] { opacity: .58; }

.pdf-tip {
  color: #6d7378;
  font-size: 22rpx;
  line-height: 1.6;
  padding: 18rpx 8rpx 0;
  text-align: center;
}

.detail-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.d-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.d-name {
  color: #1a1a1a;
  font-size: 34rpx;
  font-weight: 700;
