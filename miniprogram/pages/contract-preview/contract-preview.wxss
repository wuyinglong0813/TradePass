.document-info { flex: 1; margin-left: 14rpx; min-width: 0; }
.document-no { color: #223247; font-size: 24rpx; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.document-meta { color: #95a1af; font-size: 19rpx; margin-top: 5rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.document-actions { color: #3498ff; display: flex; flex-shrink: 0; font-size: 21rpx; }
.document-actions view { padding: 12rpx 8rpx; }
.document-actions view + view { border-left: 1rpx solid #e6edf5; }
.list-section-title { color: #8290a2; font-size: 22rpx; margin: 22rpx 28rpx 12rpx; }

/* ===== 销售单 / 送货单创建编辑器 ===== */
