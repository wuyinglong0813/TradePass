}

.pf-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
}

.pf-row + .pf-row {
  border-top: 1rpx solid #f8f8f8;
}

.pf-label {
  color: #888;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.pf-value {
  color: #333;
  font-size: 28rpx;
  text-align: right;
  word-break: break-all;
}

.pf-value.hl {
  background: #dcfce7;
  border-radius: 6rpx;
  color: #166534;
  font-weight: 600;
  font-size: 24rpx;
  padding: 4rpx 14rpx;
}

.pf-value.amount {
  color: #3498ff;
  font-size: 32rpx;
  font-weight: 700;
}

.panel-btn-wrap {
  padding: 16rpx 32rpx 16rpx;
}

.panel-btn {
  background: #f5f5f5;
  border: none;
