/* ===== 销售单 / 送货单 PDF ===== */
.document-bar {
  align-items: center; background: linear-gradient(145deg,#fff,#f5faff); border: 1rpx solid #dceafb;
  border-radius: 22rpx; display: flex; justify-content: space-between; margin: 0 24rpx 16rpx; padding: 22rpx;
}
