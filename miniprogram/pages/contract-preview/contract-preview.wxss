}

.d-status.status-active { background: #dcfce7; color: #166534; }
.d-status.status-pending { background: #fef3c7; color: #92400e; }
.d-status.status-rejected { background: #fee2e2; color: #991b1b; }
.d-status.status-done { background: #e0e7ff; color: #3730a3; }

.d-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
}

.d-row + .d-row {
