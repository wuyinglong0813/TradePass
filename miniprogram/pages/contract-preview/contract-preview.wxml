<view class="page">
  <!-- 合同信息头 -->
  <view class="contract-header">
    <view class="ch-name">{{contractName}}</view>
    <view class="ch-party">与 {{counterpartyName}} 的合同</view>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs">
    <view class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}" wx:key="key"
      data-tab="{{item.key}}" bindtap="switchTab">{{item.label}}</view>
  </view>

  <!-- ====== 合同详情 Tab ====== -->
  <block wx:if="{{activeTab === 'detail'}}">
    <view class="detail-loading" wx:if="{{!contract}}">
      <view class="loading-text">加载中...</view>
    </view>

    <view class="pdf-viewer" wx:else>
      <view class="pdf-state">
        <view class="pdf-state-dot {{pdfReady ? 'ready' : ''}}"></view>
        <text>{{pdfLoading ? '正在生成标准 PDF...' : (pdfReady ? 'PDF 已就绪' : 'A4 标准 PDF')}}</text>
      </view>

      <view class="pdf-paper" bindtap="openContractPdf">
        <view class="pdf-paper-title">{{pdfTitle}}</view>
        <view class="pdf-paper-head">
          <view>
            <view>供方：{{pdfSupplier}}</view>
            <view>需方：{{pdfBuyer}}</view>
          </view>
          <view>
            <view>合同编号：{{contract.contractNo || contract.id}}</view>
            <view>日期：{{pdfDate}}</view>
          </view>
        </view>
        <view class="pdf-section-line">一、产品名称、规格、数量、单价、金额、供货时间及数量</view>
        <view class="pdf-mini-table">
          <view class="pdf-mini-row pdf-mini-header">
            <view>名称</view><view>规格型号</view><view>单位</view><view>数量</view><view>单价</view><view>金额</view><view>备注</view>
          </view>
          <view class="pdf-mini-row" wx:for="{{[1, 2, 3, 4, 5]}}" wx:key="*this">
            <view></view><view></view><view></view><view></view><view></view><view></view><view></view>
          </view>
        </view>
        <view class="pdf-clause-lines">
          <view></view><view></view><view></view><view></view><view></view><view></view>
        </view>
        <view class="pdf-sign-table">
          <view><text>供方</text><text>单位名称（章）</text><text>法定代表人</text><text>开户银行及账号</text></view>
          <view><text>需方</text><text>单位名称（章）</text><text>法定代表人</text><text>开户银行及账号</text></view>
        </view>
        <view class="pdf-open-hint">点击查看完整 PDF</view>
      </view>

      <view class="pdf-actions">
        <button class="pdf-button primary" loading="{{pdfLoading}}" disabled="{{pdfLoading}}" bindtap="openContractPdf">查看 PDF</button>
        <button class="pdf-button secondary" loading="{{pdfLoading}}" disabled="{{pdfLoading}}" bindtap="downloadContractPdf">下载 PDF</button>
      </view>
      <view class="pdf-tip">PDF 按 A4 固定版式生成，手机端会整页等比例缩放；打开后可通过右上角菜单保存或转发。</view>
    </view>
  </block>

  <!-- 销售单 / 物流单 / 送货单 / 发票浏览 -->
  <block wx:if="{{activeTab === 'sales'}}">
    <view class="document-bar">
      <view><view class="document-title">销售单 PDF</view><view class="document-sub">选择模板并编辑本次单据内容</view></view>
      <button class="document-create" data-type="SALES_ORDER" bindtap="createBusinessDocument">＋ 创建销售单</button>
    </view>
    <view class="document-list" wx:if="{{salesDocuments.length > 0}}">
      <view class="document-card" wx:for="{{salesDocuments}}" wx:key="id">
        <view class="document-badge">销</view>
        <view class="document-info"><view class="document-no">{{item.documentNo}}</view><view class="document-meta">{{item.templateName}} · {{item.dateText}}</view></view>
        <view class="document-actions"><view data-document="{{item}}" bindtap="viewBusinessDocument">查看</view><view data-document="{{item}}" bindtap="downloadBusinessDocument">下载</view></view>
      </view>
    </view>
    <view class="list-empty compact" wx:if="{{salesDocuments.length === 0}}">
      <view class="empty-icon">📦</view><view class="empty-text">暂无销售单</view>
      <view class="empty-sub">点击上方按钮，为当前合同生成销售单</view>
    </view>
  </block>

  <block wx:if="{{activeTab === 'logistics'}}">
    <view class="document-bar">
      <view><view class="document-title">物流单图片</view><view class="document-sub">支持拍照或从相册选择，上传后按图片查看</view></view>
      <button class="document-create" loading="{{logisticsUploading}}" disabled="{{logisticsUploading}}" bindtap="chooseLogisticsImage">＋ 上传物流单</button>
    </view>
    <view class="document-list" wx:if="{{logisticsList.length > 0}}">
      <view class="document-card" wx:for="{{logisticsList}}" wx:key="id" data-document="{{item}}" bindtap="previewLogisticsImage">
        <view class="document-badge logistics">图</view>
        <view class="document-info"><view class="document-no">{{item.originalName}}</view><view class="document-meta">{{item.fileSizeText}} · {{item.dateText}}</view></view>
        <view class="document-actions"><view>查看图片</view></view>
      </view>
    </view>
    <view class="list-empty compact" wx:if="{{!logisticsLoading && logisticsList.length === 0}}">
      <view class="empty-icon">🖼️</view><view class="empty-text">暂无物流单图片</view>
      <view class="empty-sub">点击上方按钮拍照或从相册上传</view>
    </view>
    <view class="list-empty compact" wx:if="{{logisticsLoading}}">
      <view class="empty-text">物流单加载中...</view>
    </view>
  </block>

  <block wx:if="{{activeTab === 'delivery'}}">
    <view class="document-bar">
      <view><view class="document-title">送货单 PDF</view><view class="document-sub">选择模板并编辑本次单据内容</view></view>
      <button class="document-create" data-type="DELIVERY_NOTE" bindtap="createBusinessDocument">＋ 创建送货单</button>
    </view>
    <view class="document-list" wx:if="{{deliveryDocuments.length > 0}}">
      <view class="document-card" wx:for="{{deliveryDocuments}}" wx:key="id">
        <view class="document-badge delivery">送</view>
        <view class="document-info"><view class="document-no">{{item.documentNo}}</view><view class="document-meta">{{item.templateName}} · {{item.dateText}}</view></view>
        <view class="document-actions"><view data-document="{{item}}" bindtap="viewBusinessDocument">查看</view><view data-document="{{item}}" bindtap="downloadBusinessDocument">下载</view></view>
      </view>
    </view>
    <view class="list-empty compact" wx:if="{{deliveryDocuments.length === 0}}">
      <view class="empty-icon">📄</view><view class="empty-text">暂无送货单</view>
      <view class="empty-sub">点击上方按钮，选择送货单模板生成</view>
    </view>
  </block>

  <block wx:if="{{activeTab === 'invoice'}}">
    <view class="list-empty" wx:if="{{invoiceList.length === 0}}">
      <view class="empty-icon">🧾</view><view class="empty-text">发票数据源尚未接入</view>
      <view class="empty-sub">当前不生成或展示模拟发票</view>
    </view>
    <view class="list" wx:else>
      <view class="order-card" wx:for="{{invoiceList}}" wx:key="id" data-type="发票" data-item="{{item}}" bindtap="onItemTap">
        <view class="oc-top"><view class="oc-no">{{item.invoiceNo}}</view><view class="oc-status {{item.status === '已开票' ? 'done' : 'pending'}}">{{item.status}}</view></view>
        <view class="oc-body"><view class="oc-product">{{item.type}}</view><view class="oc-qty">税率{{item.taxRate}}</view></view>
        <view class="oc-bottom"><view class="oc-date">{{item.date}}</view><view class="oc-amount">¥{{item.amount}}</view></view>
      </view>
    </view>
  </block>

  <view class="page-end" wx:if="{{activeTab !== 'detail'}}">— 已经到底了 —</view>

  <!-- 销售单 / 送货单创建编辑器 -->
  <view class="document-editor-page" wx:if="{{showDocumentEditor}}">
    <view class="document-editor-header">
      <view class="document-editor-close" bindtap="closeDocumentEditor">取消</view>
      <view class="document-editor-title">创建{{documentEditorLabel}}</view>
      <view class="document-editor-close placeholder">取消</view>
    </view>

    <scroll-view class="document-editor-body" scroll-y>
      <view class="document-party-bar">
        <view class="document-party-item">
          <view class="document-party-avatar my">{{documentCompanyName[0]}}</view>
          <view class="document-party-name">{{documentCompanyName}}</view>
          <view class="document-party-tag">制单方</view>
        </view>
        <view class="document-party-vs"><image src="/images/logo.png" mode="aspectFit"/></view>
        <view class="document-party-item">
          <view class="document-party-avatar counterparty">{{documentCounterpartyName[0]}}</view>
          <view class="document-party-name">{{documentCounterpartyName}}</view>
          <view class="document-party-tag">往来单位</view>
        </view>
      </view>

      <view class="document-edit-card">
        <view class="document-form-label">{{documentEditorLabel}}模板</view>
        <picker mode="selector" range="{{documentTemplates}}" range-key="name" value="{{documentTemplateIndex}}" bindchange="onDocumentTemplateChange">
          <view class="document-template-picker {{documentTemplateIndex < 0 ? 'placeholder' : ''}}">
            {{documentTemplates[documentTemplateIndex] ? documentTemplates[documentTemplateIndex].name : '请选择模板'}} ▾
          </view>
        </picker>
      </view>

      <block wx:if="{{documentEditorReady}}">
        <view class="document-edit-card">
          <view class="document-form-label">{{documentEditorLabel}}名称</view>
          <input class="document-name-input" value="{{documentTitle}}" data-field="documentTitle" bindinput="onDocumentFieldInput" placeholder="请输入单据名称"/>
        </view>

        <view class="document-edit-card document-title-card">
          <view class="document-preview-title">{{documentTitle || documentEditorLabel}}</view>
          <view class="document-preview-no">单据编号：创建时自动生成</view>
        </view>

        <view class="document-edit-card">
          <view class="document-edit-section-title">单据信息</view>
          <view class="document-field-row">
            <view class="document-field-label">制单企业</view>
            <input class="document-field-input" value="{{documentCompanyName}}" data-field="documentCompanyName" bindinput="onDocumentFieldInput" placeholder="请输入制单企业"/>
          </view>
          <view class="document-field-row">
            <view class="document-field-label">往来单位</view>
            <input class="document-field-input" value="{{documentCounterpartyName}}" data-field="documentCounterpartyName" bindinput="onDocumentFieldInput" placeholder="请输入往来单位"/>
          </view>
          <view class="document-field-row">
            <view class="document-field-label">关联合同</view>
            <input class="document-field-input" value="{{documentContractNo}}" data-field="documentContractNo" bindinput="onDocumentFieldInput" placeholder="请输入合同编号"/>
          </view>
          <view class="document-field-row">
            <view class="document-field-label">单据日期</view>
            <picker class="document-field-picker" mode="date" value="{{documentDate}}" bindchange="onDocumentDateChange">
              <view class="document-field-value">{{documentDate || '请选择日期'}}</view>
            </picker>
          </view>
        </view>

        <view class="document-edit-card">
          <view class="document-edit-section-head">
            <view><view class="document-edit-section-title">商品明细</view><view class="document-edit-hint">左右滑动可编辑全部列</view></view>
          </view>
          <scroll-view class="document-table-scroll" scroll-x enable-flex>
            <view class="document-edit-table" style="width: {{documentColumns.length * 190 + 78}}rpx;">
              <view class="document-edit-table-row header">
                <view class="document-edit-cell" wx:for="{{documentColumns}}" wx:key="*this">{{item}}</view>
                <view class="document-edit-cell action"></view>
              </view>
              <view class="document-edit-table-row" wx:for="{{documentRows}}" wx:for-item="row" wx:for-index="rowIndex" wx:key="rowIndex">
                <view class="document-edit-cell" wx:for="{{documentColumns}}" wx:for-item="column" wx:for-index="columnIndex" wx:key="*this">
                  <input class="document-cell-input" value="{{row[columnIndex]}}" data-row="{{rowIndex}}" data-col="{{columnIndex}}" bindinput="onDocumentCellInput"/>
                </view>
                <view class="document-edit-cell action"><view class="document-row-delete" data-index="{{rowIndex}}" bindtap="deleteDocumentRow">×</view></view>
              </view>
            </view>
          </scroll-view>
          <view class="document-row-add" bindtap="addDocumentRow">＋ 添加商品行</view>
          <view class="document-total-field" wx:if="{{documentEditorType === 'SALES_ORDER'}}">
            <view class="document-total-label">合计：</view>
            <view class="document-total-value">¥{{documentTotalAmount}}</view>
          </view>
        </view>
      </block>

      <view class="document-editor-empty" wx:else>
        <view class="document-editor-empty-icon">▤</view>
        <view>请先选择一个{{documentEditorLabel}}模板</view>
      </view>
      <view class="document-editor-safe"></view>
    </scroll-view>

    <view class="document-editor-actions" wx:if="{{documentEditorReady}}">
      <button class="document-editor-button submit" loading="{{documentEditorSubmitting}}" disabled="{{documentEditorSubmitting}}" bindtap="submitBusinessDocument">创建{{documentEditorLabel}}</button>
    </view>
  </view>

  <!-- 详情面板 -->
  <view class="mask" wx:if="{{showDetail}}" bindtap="closeDetail">
    <view class="panel" catchtap="noop">
      <view class="panel-header"><view class="panel-title">{{detailTitle}}</view><view class="panel-close" bindtap="closeDetail">✕</view></view>
      <view class="timeline" wx:if="{{detailSteps && detailSteps.length > 0}}">
        <view class="tl-item" wx:for="{{detailSteps}}" wx:key="title">
          <view class="tl-dot {{item.done ? 'done' : ''}} {{item.active ? 'active' : ''}}"><view class="tl-dot-inner"></view></view>
          <view class="tl-info"><view class="tl-title {{item.active ? 'active' : ''}}">{{item.title}}</view><view class="tl-time" wx:if="{{item.time}}">{{item.time}}</view></view>
        </view>
      </view>
      <view class="panel-fields">
        <view class="pf-row" wx:for="{{detailFields}}" wx:key="label">
          <view class="pf-label">{{item.label}}</view><view class="pf-value {{item.highlight ? 'hl' : ''}} {{item.amount ? 'amount' : ''}}">{{item.value}}</view>
        </view>
      </view>
      <view class="panel-btn-wrap"><button class="panel-btn" bindtap="closeDetail">关闭</button></view>
    </view>
  </view>
</view>
