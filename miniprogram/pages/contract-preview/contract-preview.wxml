<view class="page">
  <!-- 合同信息头 -->
  <view class="contract-header">
    <view class="ch-name">{{contractName}}</view>
    <view class="ch-party">与 {{counterpartyName}} 的合同</view>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs">
    <view class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}" wx:key="key"
      data-tab="{{item.key}}" bindtap="switchTab">{{item.label}}</view>
  </view>

  <!-- ====== 合同详情 Tab ====== -->
  <block wx:if="{{activeTab === 'detail'}}">
    <view class="detail-loading" wx:if="{{!contract}}">
      <view class="loading-text">加载中...</view>
    </view>

    <view class="pdf-viewer" wx:else>
      <view class="pdf-state">
        <view class="pdf-state-dot {{pdfReady ? 'ready' : ''}}"></view>
        <text>{{pdfLoading ? '正在生成标准 PDF...' : (pdfReady ? 'PDF 已就绪' : 'A4 标准 PDF')}}</text>
      </view>

      <view class="pdf-paper" bindtap="openContractPdf">
        <view class="pdf-paper-title">{{pdfTitle}}</view>
        <view class="pdf-paper-head">
          <view>
            <view>供方：{{pdfSupplier}}</view>
            <view>需方：{{pdfBuyer}}</view>
          </view>
          <view>
            <view>合同编号：{{contract.contractNo || contract.id}}</view>
            <view>日期：{{pdfDate}}</view>
          </view>
        </view>
        <view class="pdf-section-line">一、产品名称、规格、数量、单价、金额、供货时间及数量</view>
        <view class="pdf-mini-table">
          <view class="pdf-mini-row pdf-mini-header">
            <view>名称</view><view>规格型号</view><view>单位</view><view>数量</view><view>单价</view><view>金额</view><view>备注</view>
          </view>
          <view class="pdf-mini-row" wx:for="{{[1, 2, 3, 4, 5]}}" wx:key="*this">
            <view></view><view></view><view></view><view></view><view></view><view></view><view></view>
          </view>
        </view>
        <view class="pdf-clause-lines">
          <view></view><view></view><view></view><view></view><view></view><view></view>
        </view>
        <view class="pdf-sign-table">
          <view><text>供方</text><text>单位名称（章）</text><text>法定代表人</text><text>开户银行及账号</text></view>
          <view><text>需方</text><text>单位名称（章）</text><text>法定代表人</text><text>开户银行及账号</text></view>
        </view>
        <view class="pdf-open-hint">点击查看完整 PDF</view>
      </view>

      <view class="pdf-actions">
        <button class="pdf-button primary" loading="{{pdfLoading}}" disabled="{{pdfLoading}}" bindtap="openContractPdf">查看 PDF</button>
        <button class="pdf-button secondary" loading="{{pdfLoading}}" disabled="{{pdfLoading}}" bindtap="downloadContractPdf">下载 PDF</button>
      </view>
      <view class="pdf-tip">PDF 按 A4 固定版式生成，手机端会整页等比例缩放；打开后可通过右上角菜单保存或转发。</view>
    </view>
  </block>

  <!-- 销售单 / 物流单 / 送货单 / 发票浏览 -->
  <block wx:if="{{activeTab === 'sales'}}">
    <view class="document-bar">
      <view><view class="document-title">销售单 PDF</view><view class="document-sub">按企业销售单模板生成</view></view>
      <button class="document-create" data-type="SALES_ORDER" bindtap="createBusinessDocument">＋ 创建销售单</button>
    </view>
    <view class="document-list" wx:if="{{salesDocuments.length > 0}}">
      <view class="document-card" wx:for="{{salesDocuments}}" wx:key="id">
        <view class="document-badge">销</view>
        <view class="document-info"><view class="document-no">{{item.documentNo}}</view><view class="document-meta">{{item.templateName}} · {{item.dateText}}</view></view>
        <view class="document-actions"><view data-document="{{item}}" bindtap="viewBusinessDocument">查看</view><view data-document="{{item}}" bindtap="downloadBusinessDocument">下载</view></view>
      </view>
    </view>
    <view class="list-section-title" wx:if="{{salesList.length > 0}}">关联销售订单</view>
    <view class="list-empty compact" wx:if="{{salesList.length === 0 && salesDocuments.length === 0}}">
      <view class="empty-icon">📦</view><view class="empty-text">暂无销售单</view>
    </view>
    <view class="list" wx:else>
      <view class="order-card" wx:for="{{salesList}}" wx:key="id" data-type="销售单" data-item="{{item}}" bindtap="onItemTap">
        <view class="oc-top"><view class="oc-no">{{item.orderNo}}</view><view class="oc-status {{item.status === '已确认' ? 'done' : 'pending'}}">{{item.status}}</view></view>
        <view class="oc-body"><view class="oc-product">{{item.product}}</view><view class="oc-qty">×{{item.qty}}</view></view>
        <view class="oc-bottom"><view class="oc-date">{{item.date}}</view><view class="oc-amount">¥{{item.amount}}</view></view>
      </view>
    </view>
  </block>

  <block wx:if="{{activeTab === 'logistics'}}">
    <view class="list-empty" wx:if="{{logisticsList.length === 0}}">
      <view class="empty-icon">🚚</view><view class="empty-text">暂无物流单</view>
    </view>
    <view class="list" wx:else>
      <view class="order-card" wx:for="{{logisticsList}}" wx:key="id" data-type="物流单" data-item="{{item}}" bindtap="onItemTap">
        <view class="oc-top"><view class="oc-no">{{item.trackingNo}}</view><view class="oc-status {{item.status === '已签收' ? 'done' : 'shipped'}}">{{item.status}}</view></view>
        <view class="oc-body"><view class="oc-product">{{item.carrier}}</view><view class="oc-qty">{{item.weight}}</view></view>
        <view class="oc-bottom"><view class="oc-date">{{item.date}}</view></view>
      </view>
    </view>
  </block>

  <block wx:if="{{activeTab === 'delivery'}}">
    <view class="document-bar">
      <view><view class="document-title">送货单 PDF</view><view class="document-sub">按企业送货单模板生成</view></view>
      <button class="document-create" data-type="DELIVERY_NOTE" bindtap="createBusinessDocument">＋ 创建送货单</button>
    </view>
    <view class="document-list" wx:if="{{deliveryDocuments.length > 0}}">
      <view class="document-card" wx:for="{{deliveryDocuments}}" wx:key="id">
        <view class="document-badge delivery">送</view>
        <view class="document-info"><view class="document-no">{{item.documentNo}}</view><view class="document-meta">{{item.templateName}} · {{item.dateText}}</view></view>
        <view class="document-actions"><view data-document="{{item}}" bindtap="viewBusinessDocument">查看</view><view data-document="{{item}}" bindtap="downloadBusinessDocument">下载</view></view>
      </view>
    </view>
    <view class="list-empty compact" wx:if="{{deliveryDocuments.length === 0}}">
      <view class="empty-icon">📄</view><view class="empty-text">暂无送货单</view>
      <view class="empty-sub">点击上方按钮，选择送货单模板生成</view>
    </view>
  </block>

  <block wx:if="{{activeTab === 'invoice'}}">
    <view class="list-empty" wx:if="{{invoiceList.length === 0}}">
      <view class="empty-icon">🧾</view><view class="empty-text">暂无发票</view>
    </view>
    <view class="list" wx:else>
      <view class="order-card" wx:for="{{invoiceList}}" wx:key="id" data-type="发票" data-item="{{item}}" bindtap="onItemTap">
        <view class="oc-top"><view class="oc-no">{{item.invoiceNo}}</view><view class="oc-status {{item.status === '已开票' ? 'done' : 'pending'}}">{{item.status}}</view></view>
        <view class="oc-body"><view class="oc-product">{{item.type}}</view><view class="oc-qty">税率{{item.taxRate}}</view></view>
        <view class="oc-bottom"><view class="oc-date">{{item.date}}</view><view class="oc-amount">¥{{item.amount}}</view></view>
      </view>
    </view>
  </block>

  <view class="page-end" wx:if="{{activeTab !== 'detail'}}">— 已经到底了 —</view>

  <!-- 详情面板 -->
  <view class="mask" wx:if="{{showDetail}}" bindtap="closeDetail">
    <view class="panel" catchtap="noop">
      <view class="panel-header"><view class="panel-title">{{detailTitle}}</view><view class="panel-close" bindtap="closeDetail">✕</view></view>
      <view class="timeline" wx:if="{{detailSteps && detailSteps.length > 0}}">
        <view class="tl-item" wx:for="{{detailSteps}}" wx:key="title">
          <view class="tl-dot {{item.done ? 'done' : ''}} {{item.active ? 'active' : ''}}"><view class="tl-dot-inner"></view></view>
          <view class="tl-info"><view class="tl-title {{item.active ? 'active' : ''}}">{{item.title}}</view><view class="tl-time" wx:if="{{item.time}}">{{item.time}}</view></view>
        </view>
      </view>
      <view class="panel-fields">
        <view class="pf-row" wx:for="{{detailFields}}" wx:key="label">
          <view class="pf-label">{{item.label}}</view><view class="pf-value {{item.highlight ? 'hl' : ''}} {{item.amount ? 'amount' : ''}}">{{item.value}}</view>
        </view>
      </view>
      <view class="panel-btn-wrap"><button class="panel-btn" bindtap="closeDetail">关闭</button></view>
    </view>
  </view>
</view>
