<view class="me-page">
  <view class="me-shell guest-me-shell" wx:if="{{!isLoggedIn}}">
    <view class="profile-hero guest-profile-hero">
      <image class="profile-watermark" src="/images/brand-logo.svg" mode="aspectFit"/>
      <view class="profile-main">
        <image class="guest-profile-logo" src="/images/logo.png" mode="aspectFit"/>
        <view class="profile-copy"><view class="profile-name">未登录</view><view class="profile-phone">登录后同步企业、合同与业务单据</view></view>
        <button class="guest-login-button" bindtap="goLogin">登录/注册</button>
      </view>
    </view>

    <view class="section-head">
      <view><view class="section-title">企业身份</view><view class="section-sub">登录后查看当前代表的企业主体</view></view>
      <view class="section-link" bindtap="goLogin">登录查看 ›</view>
    </view>
    <view class="company-summary guest-company-summary" bindtap="goLogin">
      <view class="company-avatar">企</view>
      <view class="company-copy"><view class="company-name">暂未登录企业身份</view><view class="company-meta">登录后创建或加入企业工作空间</view></view>
      <view class="row-arrow">›</view>
    </view>

    <view class="section-head service-head"><view><view class="section-title">账户与服务</view><view class="section-sub">未登录也可以查看协议与产品帮助</view></view></view>
    <view class="settings-list">
      <view class="setting-row" bindtap="openAccountSecurity"><image src="/images/icons/security.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">账号与安全</view><view class="setting-desc">登录后管理手机号与实名状态</view></view><view class="row-arrow">›</view></view>
      <view class="setting-row" bindtap="openPrivacy"><image src="/images/icons/privacy.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">隐私设置</view><view class="setting-desc">个人信息与授权管理</view></view><view class="row-arrow">›</view></view>
      <view class="setting-row" bindtap="openAgreement"><image src="/images/icons/agreement.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">用户协议</view><view class="setting-desc">服务条款与使用规则</view></view><view class="row-arrow">›</view></view>
      <view class="setting-row" bindtap="openHelp"><image src="/images/icons/help.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">帮助与反馈</view><view class="setting-desc">使用指引与问题反馈</view></view><view class="row-arrow">›</view></view>
      <view class="setting-row" bindtap="openAbout"><image src="/images/icons/about.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">关于商签通</view><view class="setting-desc">版本信息与品牌说明</view></view><view class="row-arrow">›</view></view>
    </view>
    <view class="page-end">商签通 · 让每一份凭证可信流转</view>
  </view>

  <block wx:else>
    <view class="me-shell">
      <view class="profile-hero">
        <image class="profile-watermark" src="/images/brand-logo.svg" mode="aspectFit"/>
        <view class="profile-main">
          <view class="profile-avatar">{{userNameFirst}}</view>
          <view class="profile-copy"><view class="profile-name">{{userDisplayName}}</view><view class="profile-phone">{{maskedPhone}}</view></view>
          <view class="profile-code" bindtap="showProfileCode"><image src="/images/icons/qr-white.svg" mode="aspectFit"/></view>
        </view>
        <view class="profile-badge">{{memberRoleText}} · {{realNameVerified ? '已实名' : '待实名'}}</view>
      </view>

      <view class="section-head">
        <view><view class="section-title">当前企业</view><view class="section-sub">当前代表的企业主体与身份</view></view>
      </view>

      <view class="company-summary" wx:if="{{companies.length > 0}}">
        <view class="company-avatar">{{companyAbbr}}</view>
        <view class="company-copy"><view class="company-name">{{company.name}}</view><view class="company-meta">{{memberRoleText}} · 当前企业</view></view>
        <view class="company-state {{companyVerified ? '' : 'pending'}}">{{companyStatusText}}</view>
      </view>
      <view class="company-summary empty-company" wx:else bindtap="goCompanyCenter">
        <view class="company-avatar">企</view><view class="company-copy"><view class="company-name">暂未加入企业</view><view class="company-meta">创建或加入企业后开始业务协作</view></view><view class="row-arrow">›</view>
      </view>

      <view class="section-head service-head"><view><view class="section-title">账户与服务</view><view class="section-sub">账户安全、隐私与产品支持</view></view></view>
      <view class="settings-list">
        <view class="setting-row" bindtap="openAccountSecurity"><image src="/images/icons/security.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">账号与安全</view><view class="setting-desc">手机号、实名状态与登录安全</view></view><view class="row-arrow">›</view></view>
        <view class="setting-row" bindtap="openPrivacy"><image src="/images/icons/privacy.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">隐私设置</view><view class="setting-desc">个人信息与授权管理</view></view><view class="row-arrow">›</view></view>
        <view class="setting-row" bindtap="openAgreement"><image src="/images/icons/agreement.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">用户协议</view><view class="setting-desc">服务条款与使用规则</view></view><view class="row-arrow">›</view></view>
        <view class="setting-row" bindtap="openHelp"><image src="/images/icons/help.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">帮助与反馈</view><view class="setting-desc">使用指引与问题反馈</view></view><view class="row-arrow">›</view></view>
        <view class="setting-row" bindtap="openAbout"><image src="/images/icons/about.svg" mode="aspectFit"/><view class="setting-copy"><view class="setting-title">关于商签通</view><view class="setting-desc">版本信息与品牌说明</view></view><view class="row-arrow">›</view></view>
      </view>

      <view class="dev-card" wx:if="{{isDev}}">
        <view class="dev-head" bindtap="toggleDev"><view><view class="section-title">开发者工具</view><view class="section-sub">仅开发环境显示</view></view><view class="row-arrow">{{devOpen ? '⌄' : '›'}}</view></view>
        <picker wx:if="{{devOpen}}" mode="selector" range="{{devUsers}}" range-key="label" value="{{devUserIndex}}" bindchange="onSwitchUser"><view class="user-picker">{{devUsers[devUserIndex].label}}⌄</view></picker>
      </view>

      <view class="logout-button" bindtap="logout">退出登录</view>
      <view class="page-end">商签通 · 让每一份凭证可信流转</view>
    </view>
  </block>
</view>
