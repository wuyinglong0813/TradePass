<view class="page">
  <!-- 未登录 -->
  <login-guard wx:if="{{!isLoggedIn}}" text="没有查到您的信息，请登录后查看"/>

  <block wx:else>
  <view class="profile card">
    <view class="hello">您好，{{userDisplayName}}</view>
    <view class="role-badge">{{memberRoleText}}</view>
  </view>

  <!-- 我的企业 -->
  <view class="card">
    <view class="section-title">我的企业</view>
    <view wx:if="{{companies.length === 0}}" class="empty">暂未加入任何企业</view>
    <block wx:for="{{companies}}" wx:key="companyId">
      <view class="company-role-row">
        <view class="company-role-name">{{item.companyName}}</view>
        <view class="company-role-tag">{{item.roleText}}</view>
        <view class="company-role-check" wx:if="{{item.companyId === currentCompanyId}}">当前</view>
      </view>
    </block>
  </view>

  <view class="card hint-card">
    <view class="hint-text">企业认证、成员与角色管理已移至底部「企业」页</view>
  </view>

  <!-- Dev 用户切换（仅开发者工具可见） -->
  <view class="card" wx:if="{{isDev}}">
    <view class="section-title">切换用户（开发）</view>
    <picker mode="selector" range="{{devUsers}}" range-key="label" value="{{devUserIndex}}" bindchange="onSwitchUser">
      <view class="user-picker">{{devUsers[devUserIndex].label}} ▾</view>
    </picker>
  </view>

  <view class="logout-btn" bindtap="logout">退出登录</view>
  </block>
</view>
