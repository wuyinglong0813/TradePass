<view class="page">
  <!-- 未登录 -->
  <login-guard wx:if="{{!isLoggedIn}}" text="没有查到您的信息，请登录后查看"/>

  <block wx:else>
  <!-- 个人信息卡片 -->
  <view class="profile-card">
    <view class="profile-bg"></view>
    <view class="profile-main">
      <view class="profile-avatar">{{userNameFirst}}</view>
      <view class="profile-info">
        <view class="profile-name">{{userDisplayName}}</view>
        <view class="profile-phone">{{maskedPhone}}</view>
      </view>
    </view>
    <view class="profile-role">{{memberRoleText}}</view>
  </view>

  <!-- 我的企业 -->
  <view class="card">
    <view class="section-title">我的企业</view>
    <view wx:if="{{companies.length === 0}}" class="empty-hint">
      <view class="empty-icon">🏢</view>
      <view class="empty-text">暂未加入任何企业</view>
    </view>
    <block wx:for="{{companies}}" wx:key="companyId">
      <view class="company-row {{item.companyId === currentCompanyId ? 'current' : ''}}">
        <view class="cr-avatar">{{item.companyName[0]}}</view>
        <view class="cr-info">
          <view class="cr-name">{{item.companyName}}</view>
          <view class="cr-tags">
            <view class="cr-tag">{{item.roleText}}</view>
            <view class="cr-check" wx:if="{{item.companyId === currentCompanyId}}">当前</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </block>
  </view>

  <!-- 设置 -->
  <view class="card">
    <view class="section-title">设置</view>
    <view class="menu-row" bindtap="openPrivacy">
      <view class="menu-icon" style="background:linear-gradient(135deg,#64748b,#94a3b8)">密</view>
      <view class="menu-label">隐私设置</view>
      <view class="arrow">›</view>
    </view>
    <view class="menu-row" bindtap="openAgreement">
      <view class="menu-icon" style="background:linear-gradient(135deg,#3b82f6,#6366f1)">协</view>
      <view class="menu-label">用户协议</view>
      <view class="arrow">›</view>
    </view>
    <view class="menu-row" bindtap="openAbout">
      <view class="menu-icon" style="background:linear-gradient(135deg,#0f766e,#14b8a6)">i</view>
      <view class="menu-label">关于商签通</view>
      <view class="arrow">›</view>
    </view>
  </view>

  <!-- 开发者工具 -->
  <view class="card dev-card" wx:if="{{isDev}}">
    <view class="section-title dev-title" bindtap="toggleDev">开发者工具 {{devOpen ? '▾' : '▸'}}</view>
    <block wx:if="{{devOpen}}">
      <picker mode="selector" range="{{devUsers}}" range-key="label" value="{{devUserIndex}}" bindchange="onSwitchUser">
        <view class="user-picker">{{devUsers[devUserIndex].label}} ▾</view>
      </picker>
    </block>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="logout">退出登录</view>

  <view class="page-end">— 已经到底了 —</view>
  </block>
</view>
