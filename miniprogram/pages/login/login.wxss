.page {
  align-items: center;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  padding: 0 60rpx;
}

.logo-area {
  align-items: center;
  display: flex;
  flex-direction: column;
  margin-bottom: 120rpx;
}

.logo-icon {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  border-radius: 40rpx;
  color: #fff;
  font-size: 72rpx;
  font-weight: 700;
  height: 140rpx;
  line-height: 140rpx;
  margin-bottom: 32rpx;
  text-align: center;
  width: 140rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.slogan {
  color: #9ca3af;
  font-size: 28rpx;
}

.login-area {
  align-items: center;
  display: flex;
  flex-direction: column;
  width: 100%;
}

.avatar {
  border-radius: 50%;
  height: 120rpx;
  margin-bottom: 16rpx;
  width: 120rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 48rpx;
  color: #1f2937;
}

.wechat-login-btn {
  align-items: center;
  background: #07c160;
  border-radius: 16rpx;
  color: #fff;
  display: flex;
  font-size: 32rpx;
  font-weight: 600;
  height: 100rpx;
  justify-content: center;
  width: 100%;
  gap: 16rpx;
}

.wechat-login-btn::after { border: none; }

.wechat-icon {
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  font-size: 24rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  width: 48rpx;
}

.phone-btn {
  background: #f3f4f6;
  border-radius: 16rpx;
  color: #374151;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin-bottom: 24rpx;
  width: 100%;
}

.phone-btn::after { border: none; }

.enter-btn {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  border-radius: 16rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  height: 100rpx;
  line-height: 100rpx;
  width: 100%;
}

.enter-btn::after { border: none; }

.agreement {
  color: #9ca3af;
  font-size: 22rpx;
  margin-top: 40rpx;
}
