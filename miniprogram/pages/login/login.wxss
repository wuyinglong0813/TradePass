.page { background: #fff; min-height: 100vh; display: flex; flex-direction: column; }

.hero-area { position: relative; flex: 1; overflow: hidden; }
.hero-bg {
  position: absolute; inset: 0;
  background: linear-gradient(160deg, #0f766e 0%, #14b8a6 40%, #99f6e4 70%, #ccfbf1 100%);
}
.hero-content { position: relative; z-index: 1; padding: 120rpx 50rpx 60rpx; display: flex; flex-direction: column; align-items: center; }
.brand-logo { color: rgba(255,255,255,0.95); font-size: 52rpx; font-weight: 700; letter-spacing: 8rpx; margin-bottom: 48rpx; }
.hero-title { color: #fff; font-size: 48rpx; font-weight: 700; margin-bottom: 16rpx; }
.hero-subtitle { color: rgba(255,255,255,0.85); font-size: 28rpx; }
.hero-img-placeholder { width: 400rpx; height: 320rpx; margin-top: 60rpx; background: rgba(255,255,255,0.15); border-radius: 32rpx; }

/* 底部登录区 */
.bottom-area { padding: 40rpx 50rpx 60rpx; background: #fff; }

.wechat-btn {
  width: 100%; height: 100rpx; line-height: 100rpx;
  background: #07c160; color: #fff; font-size: 32rpx; font-weight: 600;
  border-radius: 16rpx;
}
.wechat-btn::after { border: none; }

.agreement-row { display: flex; align-items: flex-start; gap: 12rpx; margin-top: 24rpx; padding: 0 4rpx; }
.checkbox { flex-shrink: 0; width: 34rpx; height: 34rpx; border: 2rpx solid #d1d5db; border-radius: 50%; text-align: center; line-height: 34rpx; font-size: 20rpx; color: #fff; margin-top: 2rpx; }
.checkbox.checked { background: #07c160; border-color: #07c160; }
.agreement-text { font-size: 24rpx; color: #9ca3af; line-height: 1.5; }
.link { color: #0f766e; }

.phone-btn {
  width: 100%; height: 88rpx; line-height: 88rpx; margin-top: 24rpx;
  background: #f5f5f5; color: #374151; font-size: 28rpx; border-radius: 16rpx; border: none;
}
.phone-btn::after { border: none; }
.phone-btn[disabled] { opacity: 0.4; }

.other-login { text-align: center; margin-top: 24rpx; font-size: 26rpx; color: #6b7280; }

/* 手机号弹窗 */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 200; display: flex; align-items: flex-end; justify-content: center; }
.phone-modal { background: #fff; width: 100%; border-radius: 32rpx 32rpx 0 0; padding: 48rpx 40rpx 80rpx; }
.phone-modal-title { font-size: 34rpx; font-weight: 700; margin-bottom: 32rpx; }
.phone-modal-input { background: #f5f5f5; border-radius: 16rpx; height: 96rpx; padding: 0 28rpx; font-size: 30rpx; width: 100%; box-sizing: border-box; }
.phone-modal-btn { width: 100%; height: 96rpx; line-height: 96rpx; margin-top: 28rpx; background: #0f766e; color: #fff; font-size: 30rpx; font-weight: 600; border-radius: 16rpx; }
.phone-modal-btn::after { border: none; }
.phone-modal-btn[disabled] { opacity: 0.4; }

/* 协议弹窗 */
.modal-card { background: #fff; border-radius: 20rpx; margin: 60rpx 40rpx; padding: 36rpx; max-height: 75vh; display: flex; flex-direction: column; }
.modal-title { font-size: 32rpx; font-weight: 700; margin-bottom: 20rpx; }
.agreement-content { flex: 1; max-height: 45vh; }
.agreement-h2 { font-size: 28rpx; font-weight: 700; margin-bottom: 16rpx; }
.agreement-p { color: #374151; font-size: 26rpx; line-height: 1.8; }
.agree-confirm-btn { width: 100%; height: 80rpx; line-height: 80rpx; margin-top: 24rpx; background: #0f766e; color: #fff; font-size: 28rpx; border-radius: 12rpx; }
.agree-confirm-btn::after { border: none; }
