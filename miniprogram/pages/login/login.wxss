page { background: #fff; }

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0 56rpx;
  box-sizing: border-box;
}

/* ===== 品牌区 ===== */
.branding {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding-top: 160rpx;
  padding-bottom: 80rpx;
}

.logo {
  height: 150rpx;
  width: 150rpx;
}

.app-name {
  color: #162336;
  font-size: 46rpx;
  font-weight: 700;
  margin-top: 24rpx;
}

.app-desc {
  color: #999;
  font-size: 26rpx;
  margin-top: 12rpx;
}

/* ===== 协议（快捷登录上方） ===== */
.agree-row {
  align-items: center;
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.agree-check {
  align-items: center;
  border: 2rpx solid #d0d0d0;
  border-radius: 50%;
  color: #fff;
  display: flex;
  flex-shrink: 0;
  font-size: 20rpx;
  height: 32rpx;
  justify-content: center;
  margin-right: 10rpx;
  width: 32rpx;
}

.agree-check.on {
  background: #3498ff;
  border-color: #3498ff;
}

.agree-label {
  color: #999;
  font-size: 24rpx;
  line-height: 1.5;
}

.agree-link {
  color: #3498ff;
}

.agree-hint {
  color: #bbb;
  font-size: 22rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

/* ===== 手机号快捷登录按钮 ===== */
.btn-quick-login {
  align-items: center;
  background: linear-gradient(90deg, #3498ff, #45a8ff);
  border: none;
  border-radius: 48rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 118, 110, 0.28);
  color: #fff;
  display: flex;
  font-size: 34rpx;
  font-weight: 600;
  height: 100rpx;
  justify-content: center;
  letter-spacing: 2rpx;
  width: 100%;
}

.btn-quick-login::after { border: none; }

/* ===== 输入手机号登录 / 注册 ===== */
.phone-login-link {
  color: #3498ff;
  font-size: 28rpx;
  margin-top: 36rpx;
  text-align: center;
}

/* ===== 稍后登录 ===== */
.skip-row {
  color: #aab2b0;
  font-size: 26rpx;
  margin-top: auto;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  text-align: center;
}

/* ===== 协议弹窗 ===== */
.mask {
  align-items: center;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  inset: 0;
  justify-content: center;
  position: fixed;
  z-index: 200;
}

.modal {
  background: #fff;
  border-radius: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  margin: 80rpx 48rpx;
  max-height: 75vh;
  max-width: calc(100% - 96rpx);
  overflow: hidden;
  padding: 40rpx;
  width: calc(100% - 96rpx);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.modal-body {
  box-sizing: border-box;
  flex: 1;
  max-height: 45vh;
  max-width: 100%;
  overflow-x: hidden;
  width: 100%;
}

.h2 {
  font-size: 28rpx;
  font-weight: 700;
  margin: 16rpx 0 12rpx;
}

.p {
  color: #4b5563;
  font-size: 26rpx;
  line-height: 2;
}

.modal-btn {
  background: #3498ff;
  border-radius: 12rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  height: 84rpx;
  line-height: 84rpx;
  margin-top: 24rpx;
  width: 100%;
}

.modal-btn::after { border: none; }
