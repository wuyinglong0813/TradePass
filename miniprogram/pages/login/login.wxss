.page {
  align-items: center;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 80rpx 50rpx 60rpx;
}

.logo-area {
  align-items: center;
  display: flex;
  flex-direction: column;
  margin-bottom: 80rpx;
}

.logo-icon {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  border-radius: 32rpx;
  color: #fff;
  font-size: 64rpx;
  font-weight: 700;
  height: 120rpx;
  line-height: 120rpx;
  margin-bottom: 28rpx;
  text-align: center;
  width: 120rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 10rpx;
}

.slogan {
  color: #9ca3af;
  font-size: 26rpx;
}

/* 微信登录按钮 */
.login-area {
  align-items: center;
  display: flex;
  flex-direction: column;
  width: 100%;
}

.wechat-login-btn {
  align-items: center;
  background: #07c160;
  border-radius: 16rpx;
  color: #fff;
  display: flex;
  font-size: 32rpx;
  font-weight: 600;
  height: 100rpx;
  justify-content: center;
  width: 100%;
  gap: 14rpx;
}

.wechat-login-btn::after { border: none; }

.wechat-icon {
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  font-size: 22rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  width: 44rpx;
}

/* 协议 */
.agreement-row {
  align-items: flex-start;
  display: flex;
  gap: 12rpx;
  margin-top: 32rpx;
  width: 100%;
}

.checkbox {
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  color: #fff;
  flex-shrink: 0;
  font-size: 20rpx;
  height: 36rpx;
  line-height: 36rpx;
  margin-top: 2rpx;
  text-align: center;
  width: 36rpx;
}

.checkbox.checked {
  background: #0f766e;
  border-color: #0f766e;
}

.agreement-text {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.link {
  color: #ef4444;
}

.register-hint {
  color: #9ca3af;
  font-size: 22rpx;
  margin-top: 20rpx;
}

/* 手机号登录 */
.phone-login-btn {
  background: #f3f4f6;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  color: #374151;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 32rpx;
  width: 100%;
}

.phone-login-btn::after { border: none; }
.phone-login-btn[disabled] { opacity: 0.4; }

.phone-input-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  width: 100%;
}

.phone-input {
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  flex: 1;
  font-size: 28rpx;
  padding: 0 24rpx;
  height: 88rpx;
}

.phone-submit-btn {
  background: #0f766e;
  border-radius: 16rpx;
  color: #fff;
  font-size: 26rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 32rpx;
}

.phone-submit-btn::after { border: none; }
.phone-submit-btn[disabled] { opacity: 0.4; }

.skip-btn {
  color: #9ca3af;
  font-size: 26rpx;
  margin-top: auto;
  padding: 20rpx 0 40rpx;
}

/* 协议弹窗 */
.modal-mask {
  align-items: center;
  background: rgba(0,0,0,0.45);
  bottom: 0;
  display: flex;
  justify-content: center;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 200;
}

.modal-card {
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  margin: 60rpx 40rpx;
  max-height: 75vh;
  padding: 36rpx;
  width: 100%;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.agreement-content {
  flex: 1;
  max-height: 50vh;
}

.agreement-h2 {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.agreement-p {
  color: #374151;
  font-size: 26rpx;
  line-height: 1.8;
}

.agree-confirm-btn {
  background: #0f766e;
  border-radius: 12rpx;
  color: #fff;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin-top: 24rpx;
  width: 100%;
}

.agree-confirm-btn::after { border: none; }
