page { background: #fff; }
.page { display: flex; flex-direction: column; min-height: 100vh; }

.hero {
  background: linear-gradient(160deg, #0f766e, #14b8a6, #5eead4, #ccfbf1);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 120rpx 60rpx 80rpx;
}
.brand {
  color: rgba(255,255,255,0.9);
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  margin-bottom: 40rpx;
}
.title {
  color: #fff;
  font-size: 52rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}
.subtitle {
  color: rgba(255,255,255,0.8);
  font-size: 28rpx;
}

/* 登录面板 */
.login-panel {
  background: #fff;
  flex: 1;
  padding: 48rpx 50rpx;
}

.btn-wechat {
  align-items: center;
  background: #07c160;
  border-radius: 16rpx;
  color: #fff;
  display: flex;
  font-size: 32rpx;
  font-weight: 600;
  height: 100rpx;
  justify-content: center;
  width: 100%;
}
.btn-wechat::after { border: none; }

.agree-row {
  align-items: flex-start;
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 0 4rpx;
}
.agree-check {
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  color: #fff;
  flex-shrink: 0;
  font-size: 18rpx;
  height: 34rpx;
  line-height: 34rpx;
  margin-top: 3rpx;
  text-align: center;
  width: 34rpx;
}
.agree-check.on { background: #07c160; border-color: #07c160; }
.agree-label { color: #9ca3af; font-size: 24rpx; line-height: 1.6; }
.agree-link { color: #0f766e; }

.btn-phone {
  align-items: center;
  background: #f5f5f5;
  border: none;
  border-radius: 16rpx;
  color: #374151;
  display: flex;
  font-size: 28rpx;
  height: 90rpx;
  justify-content: center;
  margin-top: 24rpx;
  width: 100%;
}
.btn-phone::after { border: none; }

.other {
  color: #6b7280;
  font-size: 26rpx;
  margin-top: 28rpx;
  text-align: center;
}

/* 弹窗 */
.mask {
  align-items: flex-end;
  background: rgba(0,0,0,0.45);
  bottom: 0; left: 0; right: 0; top: 0;
  display: flex;
  justify-content: center;
  position: fixed;
  z-index: 200;
}
.sheet {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx 80rpx;
  width: 100%;
}
.sheet-title { font-size: 34rpx; font-weight: 700; margin-bottom: 32rpx; }
.sheet-input {
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 30rpx;
  height: 96rpx;
  padding: 0 28rpx;
  width: 100%;
  box-sizing: border-box;
}
.sheet-btn {
  background: #0f766e;
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  margin-top: 28rpx;
  width: 100%;
}
.sheet-btn::after { border: none; }
.sheet-btn[disabled] { opacity: 0.4; }

.modal {
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  margin: 80rpx 48rpx;
  max-height: 75vh;
  padding: 40rpx;
  width: 100%;
}
.modal-title { font-size: 34rpx; font-weight: 700; margin-bottom: 24rpx; }
.modal-body { flex: 1; max-height: 45vh; }
.h2 { font-size: 28rpx; font-weight: 700; margin: 16rpx 0 12rpx; }
.p { color: #4b5563; font-size: 26rpx; line-height: 2; }
.modal-btn {
  background: #0f766e;
  border-radius: 12rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  height: 84rpx;
  line-height: 84rpx;
  margin-top: 24rpx;
  width: 100%;
}
.modal-btn::after { border: none; }
