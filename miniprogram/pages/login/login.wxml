<view class="page">
  <view class="hero">
    <view class="hero-text">
      <view class="brand">财源通天</view>
      <view class="title">Hi 欢迎登录</view>
      <view class="subtitle">企业贸易管理，从这里开始</view>
    </view>
  </view>

  <view class="login-panel">
    <button class="btn-wechat" bindtap="handleLogin">微信用户一键登录</button>

    <view class="agree-row">
      <view class="agree-check {{agreed ? 'on' : ''}}" bindtap="toggleAgree">
        <text wx:if="{{agreed}}">✓</text>
      </view>
      <text class="agree-label">
        登录即代表你已同意
        <text class="agree-link" catchtap="openUserAgreement">《用户许可使用协议》</text>
        和
        <text class="agree-link" catchtap="openPrivacyAgreement">《隐私协议》</text>
      </text>
    </view>

    <button class="btn-phone" open-type="getPhoneNumber" bindgetphonenumber="quickPhoneLogin">手机号快捷登录</button>

    <view class="other" bindtap="showPhoneInput">其他手机号登录 / 注册</view>
  </view>

  <!-- 手机号输入弹窗 -->
  <view class="mask" wx:if="{{showPhoneModal}}" bindtap="hidePhoneModal">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">手机号登录</view>
      <input class="sheet-input" type="number" placeholder="请输入手机号" value="{{phoneNumber}}" bindinput="onPhoneInput" maxlength="11"/>
      <button class="sheet-btn" bindtap="phoneLogin" disabled="{{phoneNumber.length < 11}}">登录</button>
    </view>
  </view>

  <!-- 协议弹窗 -->
  <view class="mask" wx:if="{{showAgreement}}" bindtap="closeAgreement">
    <view class="modal" catchtap="noop">
      <view class="modal-title">{{agreementTitle}}</view>
      <scroll-view class="modal-body" scroll-y>
        <block wx:if="{{agreementType === 'user'}}">
          <view class="h2">用户许可使用协议</view>
          <view class="p">欢迎使用财源通天！</view>
          <view class="p">一、总则</view>
          <view class="p">1.1 本协议是您与财源通天之间关于使用财源通天微信小程序服务的法律协议。</view>
          <view class="p">1.2 您在注册或使用财源通天服务前，应仔细阅读本协议。</view>
          <view class="p">二、用户账号</view>
          <view class="p">2.1 您通过微信授权登录后，即成为注册用户。</view>
          <view class="p">2.2 您应当对以您的账号进行的所有活动承担法律责任。</view>
          <view class="p">三、服务内容</view>
          <view class="p">3.1 财源通天提供企业贸易管理服务：企业认证、授权管理、销售采购排行、电子章管理等。</view>
          <view class="p">四、用户行为规范</view>
          <view class="p">4.1 不得利用本服务从事任何违法或不当行为。</view>
          <view class="p">五、免责声明</view>
          <view class="p">5.1 不对因不可抗力导致的服务中断承担责任。</view>
          <view class="p">六、其他</view>
          <view class="p">6.1 本协议适用中华人民共和国法律。</view>
        </block>
        <block wx:else>
          <view class="h2">隐私协议</view>
          <view class="p">财源通天重视您的隐私。</view>
          <view class="p">一、信息收集</view>
          <view class="p">1.1 我们收集您的微信头像、昵称和手机号，仅用于完善您的账户信息和提供更好的服务。</view>
          <view class="p">二、信息使用</view>
          <view class="p">2.1 您的个人信息仅用于财源通天服务，不会出售或分享给第三方。</view>
          <view class="p">三、您的权利</view>
          <view class="p">3.1 您可以随时查看、修改或删除您的个人信息。</view>
        </block>
      </scroll-view>
      <button class="modal-btn" bindtap="closeAgreement">我知道了</button>
    </view>
  </view>
</view>
