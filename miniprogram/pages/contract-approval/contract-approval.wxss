page { background: #f4f8fd; }
.page { padding: 0 0 calc(36rpx + env(safe-area-inset-bottom)); }
.header-bar { background: linear-gradient(138deg,#45a8ff,#2478df 76%,#1557a8); color: #fff; overflow: hidden; padding: 36rpx 32rpx 42rpx; position: relative; }
.header-mark { height: 220rpx; opacity: .08; position: absolute; right: -30rpx; top: -42rpx; width: 220rpx; }
.h-title { font-size: 36rpx; font-weight: 700; position: relative; }
.h-desc { color: rgba(255,255,255,.7); font-size: 23rpx; margin-top: 8rpx; position: relative; }
.list { padding: 22rpx 24rpx; }
.loading-hint { color: #8b9794; font-size: 25rpx; padding: 80rpx 0; text-align: center; }
.empty-hint { align-items: center; display: flex; flex-direction: column; padding: 80rpx 0; }
.empty-icon { height: 110rpx; margin-bottom: 16rpx; width: 110rpx; }
.empty-text { color: #71807c; font-size: 27rpx; }
.contract-card { background: #fff; border: 1rpx solid #e3ebf5; border-radius: 26rpx; box-shadow: 0 10rpx 30rpx rgba(22, 49, 85,.05); margin-bottom: 18rpx; padding: 28rpx; }
.cc-top { align-items: center; display: flex; justify-content: space-between; }
.cc-name { color: #162336; flex: 1; font-size: 30rpx; font-weight: 700; }
.cc-status { border-radius: 15rpx; font-size: 21rpx; padding: 5rpx 11rpx; }
.cc-status.pending { background: #fff3d6; color: #9a6511; }
.cc-party { color: #45534f; font-size: 25rpx; margin-top: 12rpx; }
.cc-dates,.cc-template { color: #8b9794; font-size: 23rpx; margin-top: 7rpx; }
.cc-amount { color: #52615e; font-size: 24rpx; margin-top: 12rpx; }
.cc-amount-value { color: #2478df; font-size: 31rpx; font-weight: 700; margin-left: 8rpx; }
.cc-terms { background: #f5f8f7; border-radius: 15rpx; color: #697673; font-size: 23rpx; line-height: 1.65; margin-top: 12rpx; padding: 14rpx; }
.cc-created { color: #a1aaa8; font-size: 20rpx; margin-top: 12rpx; }
.cc-actions { display: flex; gap: 14rpx; margin-top: 24rpx; }
.cc-btn { border: none; border-radius: 18rpx; flex: 1; font-size: 26rpx; font-weight: 600; height: 78rpx; line-height: 78rpx; padding: 0; }
.cc-btn::after { border: none; }
.cc-btn.approve { background: linear-gradient(135deg,#45a8ff,#2478df); color: #fff; }
.cc-btn.reject { background: #f1f5fa; color: #75827e; }
