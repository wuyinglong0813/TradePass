.section-head { align-items: center; display: flex; justify-content: space-between; }
.title { font-size: 32rpx; font-weight: 700; }
.invite-btn { background: #0f766e; border-radius: 8rpx; color: #fff; font-size: 24rpx; padding: 8rpx 20rpx; border: none; margin: 0; line-height: 1.4; }
button.invite-btn::after { border: none; }
.auth-card { position: relative; }
.auth-card.pending { border-left: 6rpx solid #f59e0b; }
.auth-head { align-items: center; display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.auth-member { font-size: 28rpx; font-weight: 600; }
.auth-phone { color: #9ca3af; font-size: 22rpx; margin-top: 4rpx; }
.pending-badge { background: #fef3c7; border-radius: 6rpx; color: #d97706; font-size: 22rpx; padding: 4rpx 12rpx; }
.auth-role-tag { background: #dbeafe; border-radius: 6rpx; color: #1e40af; font-size: 22rpx; padding: 4rpx 12rpx; }
.approve-btns { align-items: center; display: flex; gap: 16rpx; margin-top: 12rpx; }
.btn-approve { background: #0f766e; border-radius: 8rpx; color: #fff; font-size: 24rpx; padding: 10rpx 24rpx; }
.btn-reject { color: #ef4444; font-size: 24rpx; }
.auth-actions { text-align: right; }
.revoke-btn { color: #ef4444; font-size: 24rpx; }
.empty { color: #6b7280; padding: 40rpx 0; text-align: center; }
.modal-mask { align-items: center; background: rgba(0,0,0,0.45); bottom: 0; display: flex; justify-content: center; left: 0; position: fixed; right: 0; top: 0; z-index: 100; }
.modal-card { background: #fff; border-radius: 20rpx; margin: 0 60rpx; padding: 40rpx; width: 100%; }
.modal-title { font-size: 34rpx; font-weight: 700; margin-bottom: 24rpx; }
.role-option { align-items: center; border-bottom: 1rpx solid #eef2f7; display: flex; justify-content: space-between; padding: 24rpx 0; }
.arrow { color: #9ca3af; font-size: 48rpx; }
.btn-cancel { background: #f3f4f6; border-radius: 12rpx; color: #6b7280; font-size: 28rpx; margin-top: 24rpx; padding: 18rpx 0; text-align: center; }
