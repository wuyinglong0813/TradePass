<view class="contract-page">
  <view class="contract-hero">
    <image class="hero-mark" src="/images/brand-logo.svg" mode="aspectFit"/>
    <view class="hero-label">企业合同资产</view>
    <view class="hero-amount">¥{{summary.amount}}</view>
    <view class="hero-summary">
      <view><view class="summary-value">{{summary.total}}</view><view class="summary-label">全部合同</view></view>
      <view><view class="summary-value">{{summary.pending}}</view><view class="summary-label">待签署</view></view>
      <view><view class="summary-value">{{summary.active}}</view><view class="summary-label">履约中</view></view>
    </view>
  </view>

  <scroll-view class="filter-tabs" scroll-x enable-flex>
    <view wx:for="{{tabs}}" wx:key="key" class="filter-tab {{activeTab === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="switchTab">{{item.label}}</view>
  </scroll-view>

  <view class="contract-list">
    <view class="loading" wx:if="{{loading}}">合同台账加载中...</view>
    <view class="empty" wx:elif="{{visibleContracts.length === 0}}">
      <image src="/images/icons/contracts.svg" mode="aspectFit"/>
      <view class="empty-title">当前分类暂无合同</view>
      <view class="empty-desc">从合作企业详情发起第一份合同</view>
    </view>
    <view class="contract-item" wx:for="{{visibleContracts}}" wx:key="id" data-item="{{item}}" bindtap="openContract">
      <view class="item-top"><view class="contract-name">{{item.name}}</view><view class="status status-{{item.status}}">{{item.statusText}}</view></view>
      <view class="counterparty">{{item.counterpartyName}}</view>
      <view class="item-bottom">
        <view><view class="meta-label">合同金额</view><view class="amount">¥{{item.amount}}</view></view>
        <view><view class="meta-label">合同期限</view><view class="meta-value">{{item.startDate || '—'}} 至 {{item.endDate || '—'}}</view></view>
        <view class="arrow">›</view>
      </view>
    </view>
  </view>
</view>
