/* ===== 未登录欢迎页 ===== */
.welcome-wrap {
  min-height: 100vh;
  background: #f6f7f9;
}

.welcome-banner {
  position: relative;
  background: linear-gradient(160deg, #0a6e63 0%, #0f766e 40%, #14b8a6 100%);
  padding: 120rpx 40rpx 80rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wb-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}
.wb-c1 { width: 320rpx; height: 320rpx; top: -100rpx; right: -80rpx; }
.wb-c2 { width: 180rpx; height: 180rpx; bottom: -40rpx; left: -40rpx; }
.wb-c3 { width: 90rpx; height: 90rpx; top: 180rpx; left: 50rpx; }

.wb-icon {
  width: 160rpx;
  height: 160rpx;
  position: relative;
  z-index: 1;
}

.wb-title {
  color: #fff;
  font-size: 48rpx;
  font-weight: 700;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.wb-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  margin-top: 14rpx;
  position: relative;
  z-index: 1;
}

.wb-btn {
  background: #fff;
  border: none;
  border-radius: 48rpx;
  color: #0f766e;
  font-size: 32rpx;
  font-weight: 700;
  height: 92rpx;
  line-height: 92rpx;
  margin-top: 48rpx;
  width: 400rpx;
  position: relative;
  z-index: 1;
}
.wb-btn::after { border: none; }

/* 功能预览卡片 */
.preview-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 24rpx 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.preview-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 10rpx;
}
.preview-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

.hero {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
}

.brand {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.company-row {
  align-items: center;
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.company {
  font-size: 32rpx;
  font-weight: 600;
}

.company-arrow {
  font-size: 32rpx;
  margin-left: 8rpx;
  opacity: 0.8;
}

.role-picker {
  margin-top: 8rpx;
}

.role-picker-text {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  display: inline-block;
  font-size: 26rpx;
  padding: 10rpx 24rpx;
}

/* 关联公司 */
.counterparty-section {
  margin-top: 0;
}

.counterparty-item {
  align-items: center;
  border-bottom: 1rpx solid #eef2f7;
  display: flex;
  padding: 22rpx 0;
}

.counterparty-item:last-child {
  border-bottom: none;
}

.counterparty-name {
  font-size: 28rpx;
  font-weight: 600;
}

.add-btn {
  background: #0f766e;
  border-radius: 50%;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 300;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  width: 56rpx;
  padding: 0;
  margin: 0;
  border: none;
}
button.add-btn::after { border: none; }

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
}

.periods {
  display: flex;
  gap: 12rpx;
}

.period {
  background: #f3f4f6;
  border-radius: 16rpx;
  color: #4b5563;
  min-width: 58rpx;
  padding: 10rpx 14rpx;
  text-align: center;
}

.period.active {
  background: #ccfbf1;
  color: #0f766e;
  font-weight: 700;
}

.rank-row {
  align-items: center;
  border-bottom: 1rpx solid #eef2f7;
  display: flex;
  padding: 22rpx 0;
}

.rank-row:last-child {
  border-bottom: none;
}

.rank-no {
  background: #f59e0b;
  border-radius: 50%;
  color: #ffffff;
  font-weight: 700;
  height: 48rpx;
  line-height: 48rpx;
  margin-right: 20rpx;
  text-align: center;
  width: 48rpx;
}

.rank-main {
  flex: 1;
}

.muted {
  color: #6b7280;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.amount {
  color: #0f766e;
  font-weight: 700;
  margin-right: 12rpx;
}

.arrow {
  color: #9ca3af;
  font-size: 36rpx;
}

.loading-hint {
  color: #6b7280;
  font-size: 26rpx;
  padding: 40rpx 0;
  text-align: center;
}

/* 加入企业 */
.join-hero {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
}

.join-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.join-desc {
  font-size: 24rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.join-form {
  display: flex;
  gap: 16rpx;
}

.join-input {
  background: rgba(255,255,255,0.2);
  border-radius: 12rpx;
  color: #fff;
  flex: 1;
  font-size: 28rpx;
  padding: 18rpx 24rpx;
}

.welcome-hero {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
  padding: 80rpx 40rpx;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  margin-bottom: 40rpx;
  opacity: 0.85;
}

.welcome-btn {
  background: #ffffff;
  border-radius: 16rpx;
  color: #0f766e;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 0;
  width: 100%;
}

.welcome-btn::after { border: none; }

.join-input::placeholder {
  color: rgba(255,255,255,0.6);
}

.join-btn {
  background: #ffffff;
  border-radius: 12rpx;
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 600;
  padding: 18rpx 32rpx;
}
