/* ===== 搜索企业页 ===== */

/* 顶部 Banner */
.bind-banner {
  position: relative;
  background: linear-gradient(160deg, #0a6e63 0%, #0f766e 40%, #14b8a6 100%);
  padding: 40rpx 40rpx 44rpx;
  overflow: hidden;
}

.bind-banner-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.bind-circle-lg {
  width: 240rpx;
  height: 240rpx;
  top: -60rpx;
  right: -50rpx;
}

.bind-circle-md {
  width: 130rpx;
  height: 130rpx;
  bottom: -20rpx;
  left: -20rpx;
}

.bind-banner-title {
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  position: relative;
  z-index: 1;
}

.bind-banner-sub {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 12rpx;
  line-height: 1.5;
  position: relative;
  z-index: 1;
}

/* 搜索栏 */
.search-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 28rpx 20rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 48rpx;
  padding: 0 24rpx;
  height: 88rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
}

.search-clear {
  font-size: 28rpx;
  color: #9ca3af;
  padding: 8rpx;
}

.search-btn {
  background: linear-gradient(90deg, #0f766e, #14b8a6);
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 36rpx;
}

.search-btn::after {
  border: none;
}

/* 搜索结果 */
.results-wrap {
  padding: 0 28rpx;
}

.results-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #374151;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-hint {
  color: #9ca3af;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 28rpx 32rpx;
  margin-bottom: 20rpx;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.result-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
  padding-right: 40rpx;
}

.result-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.result-label {
  color: #9ca3af;
  font-size: 24rpx;
  width: 140rpx;
  flex-shrink: 0;
}

.result-value {
  color: #4b5563;
  font-size: 24rpx;
}

.result-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #9ca3af;
  font-size: 44rpx;
}

/* 已选中确认区 */
.confirm-wrap {
  padding: 0 28rpx;
}

.confirm-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.confirm-label {
  font-size: 24rpx;
  color: #0f766e;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.confirm-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}

.confirm-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.confirm-row:last-of-type {
  border-bottom: none;
}

.confirm-key {
  color: #9ca3af;
  font-size: 26rpx;
  width: 210rpx;
  flex-shrink: 0;
}

.confirm-val {
  color: #374151;
  font-size: 26rpx;
  font-weight: 500;
}

.confirm-btn {
  background: linear-gradient(90deg, #0f766e, #14b8a6);
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 28rpx;
  width: 100%;
}

.confirm-btn::after {
  border: none;
}
