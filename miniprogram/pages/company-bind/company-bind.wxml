<view class="page">
  <!-- 顶部 Banner -->
  <view class="bind-banner">
    <view class="bind-banner-circle bind-circle-lg"></view>
    <view class="bind-banner-circle bind-circle-md"></view>
    <view class="bind-banner-title">搜索企业</view>
    <view class="bind-banner-sub">搜索您的企业工商信息，确认后完成绑定</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar-wrap">
    <view class="search-bar">
      <view class="search-icon">🔍</view>
      <input class="search-input" placeholder="请输入企业名称（与营业执照上一致）" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="doSearch" />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="clearKeyword">✕</view>
    </view>
    <button class="search-btn" bindtap="doSearch">搜索</button>
  </view>

  <!-- 搜索结果列表（未选中时） -->
  <view class="results-wrap" wx:if="{{!selectedCompany && searched}}">
    <view class="results-empty" wx:if="{{results.length === 0}}">
      <view class="empty-icon">📭</view>
      <view class="empty-text">未找到相关企业</view>
      <view class="empty-hint">请尝试更换关键词搜索</view>
    </view>
    <block wx:for="{{results}}" wx:key="creditCode">
      <view class="result-card" data-index="{{index}}" bindtap="selectCompany">
        <view class="result-name">{{item.name}}</view>
        <view class="result-row">
          <text class="result-label">法定代表人</text>
          <text class="result-value">{{item.legalPersonName}}</text>
        </view>
        <view class="result-arrow">›</view>
      </view>
    </block>
  </view>

  <!-- 已选中企业详情（待确认） -->
  <view class="confirm-wrap" wx:if="{{selectedCompany}}">
    <view class="confirm-card">
      <view class="confirm-label">已选择企业</view>
      <view class="confirm-name">{{selectedCompany.name}}</view>
      <view class="confirm-row">
        <text class="confirm-key">法定代表人</text>
        <text class="confirm-val">{{selectedCompany.legalPersonName}}</text>
      </view>
      <button class="confirm-btn" bindtap="confirmCompany">确认</button>
    </view>
  </view>
</view>
