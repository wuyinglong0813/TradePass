page { background: #f5f6f8; }

.page {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ===== 通用 ===== */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 24rpx;
  padding: 28rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.section-title {
  align-items: center;
  display: flex;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.arrow { color: #ccc; font-size: 40rpx; flex-shrink: 0; }

.page-end {
  color: #ccc;
  font-size: 22rpx;
  padding: 24rpx 0 40rpx;
  text-align: center;
}

/* ===== 企业卡片 ===== */
.company-card {
  background: linear-gradient(160deg, #0f766e, #14b8a6);
  margin-top: 0;
  border-radius: 0 0 20rpx 20rpx;
}

.cc-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.cc-name-row {
  align-items: center;
  display: flex;
  gap: 16rpx;
}

.cc-avatar {
  align-items: center;
  background: rgba(255,255,255,0.25);
  border-radius: 16rpx;
  color: #fff;
  display: flex;
  font-size: 32rpx;
  font-weight: 700;
  height: 72rpx;
  justify-content: center;
  width: 72rpx;
}

.cc-name {
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
}

.cc-switch {
  color: rgba(255,255,255,0.9);
  font-size: 24rpx;
}

.cc-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.cc-badge {
  background: #fff;
  border: 1rpx solid;
  border-radius: 8rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
}

.cc-role {
  background: rgba(255,255,255,0.22);
  border-radius: 8rpx;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
}

.cc-meta {
  color: rgba(255,255,255,0.8);
  font-size: 24rpx;
  margin-top: 20rpx;
}

/* 认证进度条 */
.cc-progress {
  margin-top: 20rpx;
}

.cc-progress-bar {
  background: rgba(255,255,255,0.25);
  border-radius: 8rpx;
  height: 10rpx;
  overflow: hidden;
}

.cc-progress-fill {
  background: #fff;
  border-radius: 8rpx;
  height: 100%;
  transition: width 0.4s;
}

.cc-progress-text {
  color: rgba(255,255,255,0.75);
  font-size: 22rpx;
  margin-top: 8rpx;
}

.cc-ok {
  color: rgba(255,255,255,0.9);
  font-size: 24rpx;
  margin-top: 20rpx;
}

.cc-ok-icon {
  background: #22c55e;
  border-radius: 50%;
  color: #fff;
  display: inline-block;
  font-size: 18rpx;
  height: 28rpx;
  line-height: 28rpx;
  margin-right: 6rpx;
  text-align: center;
  width: 28rpx;
}

/* ===== 待办中心 ===== */
.todo-card {
  border-left: 8rpx solid #f59e0b;
}

.todo-count {
  background: #ef4444;
  border-radius: 20rpx;
  color: #fff;
  font-size: 20rpx;
  font-weight: 400;
  margin-left: 8rpx;
  padding: 2rpx 12rpx;
}

.todo-row {
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  padding: 20rpx 0;
}

.todo-row:last-child { border-bottom: none; }

.todo-icon {
  font-size: 36rpx;
  margin-right: 18rpx;
}

.todo-main { flex: 1; }

.todo-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 600;
}

.todo-desc {
  color: #999;
  font-size: 23rpx;
  margin-top: 4rpx;
}

.todo-badge {
  background: #fef2f2;
  border-radius: 20rpx;
  color: #ef4444;
  font-size: 22rpx;
  margin-right: 8rpx;
  padding: 2rpx 14rpx;
}

/* ===== 管理菜单 ===== */
.menu-row {
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  padding: 22rpx 0;
}

.menu-row:last-child { border-bottom: none; }

.menu-icon {
  width: 80rpx; height: 80rpx; border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 700; color: #fff; margin-right: 20rpx; flex-shrink: 0;
}

.menu-main { flex: 1; }

.menu-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.menu-desc {
  color: #999;
  font-size: 23rpx;
  margin-top: 4rpx;
}

/* ===== 我的企业列表 ===== */
.company-role-row {
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  padding: 20rpx 0;
}

.company-role-row:last-child { border-bottom: none; }

.company-role-row.current {
  background: #f0fdfa;
  border-radius: 12rpx;
  margin: 0 -16rpx;
  padding: 20rpx 16rpx;
}

.cr-avatar {
  align-items: center;
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  border-radius: 12rpx;
  color: #fff;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 68rpx;
  justify-content: center;
  margin-right: 18rpx;
  width: 68rpx;
}

.cr-info { flex: 1; }

.cr-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.cr-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 6rpx;
}

.cr-tag {
  background: #ccfbf1;
  border-radius: 6rpx;
  color: #0f766e;
  font-size: 22rpx;
  padding: 2rpx 10rpx;
}

.cr-check {
  background: #eef2ff;
  border-radius: 6rpx;
  color: #4f46e5;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
}

/* ===== 底部操作 ===== */
.add-actions {
  border-top: 1rpx dashed #e8e8e8;
  margin-top: 12rpx;
  padding-top: 20rpx;
}

.add-btn {
  color: #0f766e;
  font-size: 28rpx;
  padding: 16rpx 0;
}

/* ===== 无企业空态 ===== */
.no-company {
  min-height: 100vh;
  background: #f6f7f9;
}

.nc-banner {
  position: relative;
  background: linear-gradient(160deg, #0a6e63 0%, #0f766e 40%, #14b8a6 100%);
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.nc-banner-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.nc-circle-lg { width: 300rpx; height: 300rpx; top: -80rpx; right: -60rpx; }
.nc-circle-md { width: 160rpx; height: 160rpx; bottom: -30rpx; left: -30rpx; }
.nc-circle-sm { width: 80rpx; height: 80rpx; top: 60rpx; left: 50rpx; }

.nc-banner-title {
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 10rpx;
  position: relative;
  z-index: 1;
}

.nc-body {
  background: #f6f7f9;
  padding: 0 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -40rpx;
}

.nc-icon-box {
  width: 120rpx;
  height: 120rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-top: -60rpx;
  position: relative;
  z-index: 2;
}

.nc-icon { font-size: 56rpx; }

.nc-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 32rpx;
}

.nc-desc {
  color: #9ca3af;
  font-size: 26rpx;
  margin-top: 12rpx;
  text-align: center;
  line-height: 1.6;
}

.nc-btn {
  background: linear-gradient(90deg, #0f766e, #14b8a6);
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 48rpx;
  padding: 24rpx 0;
  width: 400rpx;
}

.nc-btn::after { border: none; }

.nc-link {
  color: #0f766e;
  font-size: 28rpx;
  margin-top: 28rpx;
}

/* ===== 加入弹层 ===== */
.mask { align-items: flex-end; background: rgba(0,0,0,0.45); display: flex; inset: 0; justify-content: center; position: fixed; z-index: 200; }
.sheet { background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 48rpx 40rpx 80rpx; width: 100%; }
.sheet-title { font-size: 34rpx; font-weight: 700; margin-bottom: 32rpx; }
.sheet-input { background: #f5f5f5; border-radius: 16rpx; box-sizing: border-box; font-size: 30rpx; height: 96rpx; padding: 0 28rpx; width: 100%; }
.sheet-btn { background: #0f766e; border-radius: 48rpx; color: #fff; font-size: 30rpx; font-weight: 600; height: 96rpx; line-height: 96rpx; margin-top: 28rpx; width: 100%; }
.sheet-btn::after { border: none; }
