.section-title { font-size: 32rpx; font-weight: 700; margin-bottom: 16rpx; }

.company-card { background: linear-gradient(160deg, #0f766e, #14b8a6); }
.cc-head { align-items: center; display: flex; justify-content: space-between; }
.cc-name { color: #fff; font-size: 36rpx; font-weight: 700; }
.cc-switch { color: rgba(255,255,255,0.9); font-size: 24rpx; }
.cc-tags { display: flex; gap: 12rpx; margin-top: 20rpx; }
.cc-badge { background: #fff; border: 1rpx solid; border-radius: 8rpx; font-size: 22rpx; padding: 4rpx 16rpx; }
.cc-role { background: rgba(255,255,255,0.22); border-radius: 8rpx; color: #fff; font-size: 22rpx; padding: 4rpx 16rpx; }
.cc-meta { color: rgba(255,255,255,0.85); font-size: 24rpx; margin-top: 20rpx; }

.todo-count { background: #ef4444; border-radius: 20rpx; color: #fff; font-size: 20rpx; margin-left: 8rpx; padding: 2rpx 12rpx; }
.todo-row { align-items: center; border-bottom: 1rpx solid #eef2f7; display: flex; padding: 22rpx 0; }
.todo-row:last-child { border-bottom: none; }
.todo-dot { background: #f59e0b; border-radius: 50%; height: 14rpx; margin-right: 18rpx; width: 14rpx; }
.todo-main { flex: 1; }
.todo-title { color: #111827; font-size: 28rpx; font-weight: 600; }
.todo-desc { color: #9ca3af; font-size: 23rpx; margin-top: 6rpx; }
.todo-badge { background: #fef2f2; border-radius: 20rpx; color: #ef4444; font-size: 22rpx; margin-right: 8rpx; padding: 2rpx 14rpx; }

.menu-row { align-items: center; border-bottom: 1rpx solid #eef2f7; display: flex; padding: 24rpx 0; }
.menu-row:last-child { border-bottom: none; }
.menu-label { font-size: 30rpx; font-weight: 600; margin-right: 16rpx; }
.menu-desc { color: #9ca3af; flex: 1; font-size: 24rpx; }
.arrow { color: #9ca3af; font-size: 48rpx; }

.company-role-row { align-items: center; border-bottom: 1rpx solid #eef2f7; display: flex; padding: 20rpx 0; }
.company-role-name { flex: 1; font-size: 28rpx; font-weight: 600; }
.company-role-tag { background: #ccfbf1; border-radius: 6rpx; color: #0f766e; font-size: 22rpx; margin-right: 12rpx; padding: 4rpx 12rpx; }
.company-role-check { background: #eef2ff; border-radius: 6rpx; color: #4f46e5; font-size: 20rpx; padding: 4rpx 12rpx; }
.add-row { color: #0f766e; font-size: 28rpx; padding: 22rpx 0 4rpx; }

/* ===== 无企业空态 ===== */
.no-company {
  min-height: 100vh;
  background: #f6f7f9;
}

/* 顶部青绿 Banner */
.nc-banner {
  position: relative;
  background: linear-gradient(160deg, #0a6e63 0%, #0f766e 40%, #14b8a6 100%);
  height: 440rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.nc-banner-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.nc-circle-lg {
  width: 360rpx;
  height: 360rpx;
  top: -100rpx;
  right: -80rpx;
}

.nc-circle-md {
  width: 200rpx;
  height: 200rpx;
  bottom: -40rpx;
  left: -40rpx;
}

.nc-circle-sm {
  width: 100rpx;
  height: 100rpx;
  top: 80rpx;
  left: 60rpx;
}

.nc-banner-title {
  color: #fff;
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: 12rpx;
  position: relative;
  z-index: 1;
}

/* 下方内容区 */
.nc-body {
  background: #f6f7f9;
  padding: 0 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -40rpx;
}

.nc-icon-box {
  width: 140rpx;
  height: 140rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-top: -70rpx;
  position: relative;
  z-index: 2;
}

.nc-icon {
  font-size: 64rpx;
}

.nc-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 40rpx;
}

.nc-desc {
  color: #9ca3af;
  font-size: 26rpx;
  margin-top: 16rpx;
  text-align: center;
  line-height: 1.6;
}

.nc-btn {
  background: linear-gradient(90deg, #0f766e, #14b8a6);
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 56rpx;
  padding: 24rpx 0;
  width: 400rpx;
}

.nc-btn::after {
  border: none;
}

.nc-link {
  color: #0f766e;
  font-size: 28rpx;
  margin-top: 32rpx;
}

.mask { align-items: flex-end; background: rgba(0,0,0,0.45); display: flex; inset: 0; justify-content: center; position: fixed; z-index: 200; }
.sheet { background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 48rpx 40rpx 80rpx; width: 100%; }
.sheet-title { font-size: 34rpx; font-weight: 700; margin-bottom: 32rpx; }
.sheet-input { background: #f5f5f5; border-radius: 16rpx; box-sizing: border-box; font-size: 30rpx; height: 96rpx; padding: 0 28rpx; width: 100%; }
.sheet-btn { background: #0f766e; border-radius: 48rpx; color: #fff; font-size: 30rpx; font-weight: 600; height: 96rpx; line-height: 96rpx; margin-top: 28rpx; width: 100%; }
.sheet-btn::after { border: none; }
