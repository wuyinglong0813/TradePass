page { background: #f4f8fd; }

.company-page {
  background:
    radial-gradient(circle at 104% 2%, rgba(69,168,255,.16) 0, rgba(69,168,255,.16) 110rpx, transparent 260rpx),
    radial-gradient(circle at -8% 48%, rgba(194,225,255,.34) 0, rgba(194,225,255,.34) 100rpx, transparent 300rpx),
    linear-gradient(160deg,#f7fbff 0%,#f4f8fd 54%,#edf5ff 100%);
  min-height: 100vh;
  padding-bottom: calc(38rpx + env(safe-area-inset-bottom));
}

.enterprise-shell { padding: 24rpx; }
.identity-card {
  background:
    radial-gradient(circle at 93% 0%,rgba(255,255,255,.17) 0,rgba(255,255,255,.17) 92rpx,transparent 220rpx),
    linear-gradient(138deg,#45a8ff 0%,#3498ff 42%,#2478df 78%,#1557a8 100%);
  border-radius: 34rpx;
  box-shadow: 0 20rpx 50rpx rgba(36,120,223,.2);
  color: #fff;
  overflow: hidden;
  padding: 34rpx;
  position: relative;
}
.identity-watermark { height: 260rpx; opacity: .075; position: absolute; right: -58rpx; top: -70rpx; width: 260rpx; }
.identity-top,.trust-row,.section-head,.list-row,.primary-action,.primary-action-label,.readonly-card { align-items: center; display: flex; }
.identity-top,.trust-row { position: relative; }
.identity-avatar {
  align-items: center; background: rgba(255,255,255,.16); border: 1rpx solid rgba(255,255,255,.24);
  border-radius: 25rpx; display: flex; flex-shrink: 0; font-size: 31rpx; font-weight: 700;
  height: 94rpx; justify-content: center; letter-spacing: 1rpx; width: 94rpx;
}
.identity-copy { flex: 1; margin-left: 20rpx; min-width: 0; }
.identity-name { font-size: 33rpx; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.identity-code { color: rgba(255,255,255,.7); font-size: 20rpx; margin-top: 8rpx; }
.identity-arrow { color: rgba(255,255,255,.8); font-size: 39rpx; margin-left: 12rpx; }
.trust-row { border-top: 1rpx solid rgba(255,255,255,.17); justify-content: space-between; margin-top: 28rpx; padding-top: 23rpx; }
.trust-state { align-items: center; display: flex; font-size: 23rpx; font-weight: 500; }
.trust-dot { align-items: center; background: rgba(255,255,255,.18); border-radius: 50%; display: flex; font-size: 18rpx; height: 34rpx; justify-content: center; margin-right: 9rpx; width: 34rpx; }
.role-badge { background: rgba(255,255,255,.14); border: 1rpx solid rgba(255,255,255,.18); border-radius: 18rpx; font-size: 21rpx; padding: 6rpx 13rpx; }

.metrics-card {
  background: linear-gradient(145deg,#fff 0%,#fafdff 55%,#f2f8ff 100%); border: 1rpx solid #dceafa;
  border-radius: 26rpx; box-shadow: 0 12rpx 34rpx rgba(22,49,85,.06); display: grid;
  grid-template-columns: 1fr 1rpx 1fr 1rpx 1fr; margin-top: 18rpx; overflow: hidden;
}
.metric-item { padding: 24rpx 8rpx; text-align: center; }
.metric-value { color: #162336; font-size: 33rpx; font-weight: 700; }
.metric-label { color: #8b97a5; font-size: 20rpx; margin-top: 4rpx; }
.metric-divider { background: #e5eef8; height: 58rpx; margin: auto 0; }

.section-head { justify-content: space-between; margin: 34rpx 4rpx 15rpx; }
.section-title { color: #162336; font-size: 30rpx; font-weight: 700; }
.section-sub { color: #8e9aaa; font-size: 21rpx; margin-top: 5rpx; }
.section-link { color: #728198; font-size: 21rpx; }
.count-pill,.state-pill { background: #e8f3ff; border-radius: 18rpx; color: #3498ff; font-size: 20rpx; padding: 5rpx 11rpx; white-space: nowrap; }
.state-pill.muted { background: #f0f3f8; color: #7d8a9b; }
.state-pill.pending,.state-pill.attention { background: #fff3d6; color: #9a6511; }

.brand-list {
  background: linear-gradient(145deg,#fff 0%,#fff 54%,#f5f9ff 100%); border: 1rpx solid #dfeaf6;
  border-radius: 28rpx; box-shadow: 0 12rpx 34rpx rgba(22,49,85,.055); overflow: hidden;
}
.list-row { border-bottom: 1rpx solid #eaf0f7; gap: 15rpx; min-height: 104rpx; padding: 13rpx 22rpx; }
.list-row:last-child { border-bottom: none; }
.row-icon { border-radius: 21rpx; flex-shrink: 0; height: 76rpx; overflow: hidden; position: relative; width: 76rpx; }
.row-icon image { height: 100%; width: 100%; }
.row-copy { flex: 1; min-width: 0; }
.row-title { color: #1b2a3c; font-size: 26rpx; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.row-desc { color: #8e9aaa; font-size: 20rpx; margin-top: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.row-arrow { color: #a9b4c1; flex-shrink: 0; font-size: 36rpx; }

.primary-action {
  background: linear-gradient(135deg,#45a8ff,#3498ff 54%,#2478df); border-radius: 25rpx;
  box-shadow: 0 16rpx 36rpx rgba(52,152,255,.2); color: #fff; font-size: 25rpx;
  font-weight: 600; justify-content: space-between; margin-top: 22rpx; min-height: 88rpx; padding: 0 27rpx;
}
.action-plus { align-items: center; background: rgba(255,255,255,.16); border: 1rpx solid rgba(255,255,255,.2); border-radius: 14rpx; display: flex; font-size: 29rpx; height: 48rpx; justify-content: center; margin-right: 13rpx; width: 48rpx; }
.readonly-card { background: #fff; border: 1rpx solid #dfeaf6; border-radius: 28rpx; gap: 18rpx; padding: 24rpx; }
.readonly-card image { border-radius: 20rpx; height: 76rpx; width: 76rpx; }

.company-section-head { margin-top: 38rpx; }
.company-list .company-row.current { background: linear-gradient(90deg,#f2f8ff,#fbfdff); }
.company-avatar { align-items: center; background: #e8f3ff; border: 1rpx solid #d6e8fb; border-radius: 20rpx; color: #3498ff; display: flex; flex-shrink: 0; font-size: 24rpx; font-weight: 700; height: 72rpx; justify-content: center; width: 72rpx; }
.company-actions { border-top: 1rpx dashed #dce7f2; color: #3498ff; display: grid; font-size: 23rpx; grid-template-columns: 1fr 1fr; text-align: center; }
.company-actions view { padding: 23rpx 8rpx; }
.company-actions view + view { border-left: 1rpx solid #e8eff6; }

.no-company { min-height: 100vh; }
.no-company-hero { align-items: center; background: linear-gradient(145deg,#45a8ff,#2478df); color: #fff; display: flex; flex-direction: column; padding: 90rpx 40rpx 120rpx; }
.no-company-hero image { border-radius: 30rpx; height: 130rpx; width: 130rpx; }
.nc-title { font-size: 36rpx; font-weight: 700; margin-top: 26rpx; }
.nc-desc { color: rgba(255,255,255,.72); font-size: 24rpx; margin-top: 10rpx; text-align: center; }
.nc-actions { background: #fff; border: 1rpx solid #dfeaf6; border-radius: 28rpx; box-shadow: 0 14rpx 38rpx rgba(22,49,85,.09); margin: -54rpx 24rpx 0; padding: 28rpx; position: relative; }
.primary-button { background: linear-gradient(135deg,#45a8ff,#2478df); border: none; border-radius: 22rpx; color: #fff; font-size: 27rpx; font-weight: 600; height: 82rpx; line-height: 82rpx; }
.primary-button::after { border: none; }
.secondary-action { color: #3498ff; font-size: 25rpx; margin-top: 24rpx; text-align: center; }
.page-end { color: #98a4b2; font-size: 20rpx; padding: 34rpx 0 8rpx; text-align: center; }

.mask { align-items: center; background: rgba(13,35,64,.62); bottom: 0; display: flex; justify-content: center; left: 0; position: fixed; right: 0; top: 0; z-index: 200; }
.modal,.sheet { background: #fff; border-radius: 30rpx; margin: 0 48rpx; padding: 38rpx; width: 100%; }
.modal { align-items: center; display: flex; flex-direction: column; }
.modal image { height: 104rpx; width: 104rpx; }
.modal-title,.sheet-title { color: #162336; font-size: 32rpx; font-weight: 700; margin-top: 16rpx; }
.sheet-title { margin-top: 0; }
.modal-body,.sheet-desc { color: #69798d; font-size: 24rpx; margin: 12rpx 0 26rpx; text-align: center; }
.sheet-input { background: #f2f6fb; border: 1rpx solid #dfe8f3; border-radius: 18rpx; font-size: 26rpx; height: 80rpx; margin-bottom: 20rpx; padding: 0 20rpx; }
