page {
  background: #f4f8fd;
  color: #162336;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e2ebf5;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(22, 49, 85, 0.055);
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.muted {
  color: #7d8986;
}

button {
  font-family: inherit;
}

.brand-primary-button {
  background: linear-gradient(135deg, #45a8ff, #2478df);
  border: none;
  border-radius: 22rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.brand-primary-button::after {
  border: none;
}

/* 未登录态：首页、企业、我的统一登录入口 */
.guest-login-button {
  background: linear-gradient(145deg, #ffffff 0%, #f2f8ff 100%);
  border: 1rpx solid rgba(36, 120, 223, 0.2);
  border-radius: 18rpx;
  box-shadow: 0 8rpx 20rpx rgba(21, 87, 168, 0.12);
  box-sizing: border-box;
  color: #2478df;
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
  height: 64rpx;
  line-height: 62rpx;
  margin: 0 0 0 18rpx;
  min-width: 138rpx;
  padding: 0 18rpx;
  text-align: center;
  white-space: nowrap;
}

.guest-login-button::after {
  border: none;
}

/* 商签通小程序隐私保护指引：全局统一正文样式 */
.privacy-document {
  box-sizing: border-box;
  color: #52615e;
  font-size: 25rpx;
  line-height: 1.8;
  max-width: 100%;
  overflow-wrap: anywhere;
  padding-bottom: 20rpx;
  white-space: normal;
  word-break: break-all;
}

.privacy-scroll-content {
  box-sizing: border-box;
  max-width: 100%;
  overflow-x: hidden;
  width: auto;
}

.privacy-version {
  color: #8b9693;
  font-size: 22rpx;
  margin-bottom: 20rpx;
}

.privacy-lead {
  background: #f4f8fd;
  border: 1rpx solid #e2edf8;
  border-radius: 18rpx;
  box-sizing: border-box;
  color: #34475d;
  max-width: 100%;
  overflow-wrap: anywhere;
  padding: 22rpx 24rpx;
  white-space: normal;
  width: 100%;
  word-break: break-all;
}

.privacy-section {
  margin-top: 28rpx;
}

.privacy-section-title {
  color: #162336;
  font-size: 29rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.privacy-item {
  border-bottom: 1rpx solid #edf2f7;
  box-sizing: border-box;
  max-width: 100%;
  padding: 14rpx 0 18rpx;
  width: 100%;
}

.privacy-item:last-child {
  border-bottom: 0;
}

.privacy-item-title {
  color: #2d4055;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.privacy-item-desc,
.privacy-paragraph {
  color: #56667a;
  display: block;
  max-width: 100%;
  overflow-wrap: anywhere;
  white-space: normal;
  width: 100%;
  word-break: break-all;
}

.privacy-note {
  background: #edf7ff;
  border-radius: 14rpx;
  box-sizing: border-box;
  color: #2478df;
  font-size: 23rpx;
  max-width: 100%;
  margin-top: 14rpx;
  overflow-wrap: anywhere;
  padding: 16rpx 20rpx;
  white-space: normal;
  width: 100%;
  word-break: break-all;
}
