.sb {
  align-items: center;
  background: #f3f4f6;
  border-radius: 36rpx;
  display: flex;
  height: 72rpx;
  padding: 0 24rpx;
}
.sb-icon { color: #9ca3af; font-size: 26rpx; margin-right: 12rpx; }
.sb-input { color: #111827; flex: 1; font-size: 28rpx; }
.sb-clear { color: #9ca3af; font-size: 26rpx; padding: 0 8rpx; }
