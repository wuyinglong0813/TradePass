.es {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding: 100rpx 56rpx 60rpx;
}
.es-img { height: 180rpx; opacity: 0.9; width: 180rpx; }
.es-text { color: #9aa3a1; font-size: 26rpx; margin-top: 28rpx; text-align: center; }
.es-btn {
  background: linear-gradient(90deg, #3498ff, #45a8ff);
  border: none;
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 36rpx;
  padding: 16rpx 56rpx;
}
.es-btn::after { border: none; }

.es-compact { padding: 32rpx 24rpx 24rpx; }
.es-compact .es-img { height: 120rpx; width: 120rpx; }
.es-compact .es-text { font-size: 24rpx; margin-top: 16rpx; }
.es-compact .es-btn { font-size: 26rpx; margin-top: 24rpx; padding: 12rpx 40rpx; }
